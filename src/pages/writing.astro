---
// Writing (Phase 0.5 stub). Header + body each in an island; one page, one
// background, posts open in place later.
import PageShell from "../layouts/PageShell.astro";
import Island from "../components/Island.astro";
import SketchField from "../components/SketchField.astro";
---

<PageShell title="Writing" active="writing">
  {/* Rough proportion block-in of a writer at a desk, drawn from math primitives. */}
  <SketchField slot="background" />
  <Island as="header">
    <p class="eyebrow">Essays & notes</p>
    <h1>Writing</h1>
    <p class="lead">Longer-form writing — starting with AI safety.</p>
  </Island>

  <Island>
    <p class="text-secondary">
      Posts arrive in Phase 1.5, opening in place on a shared background. The
      first will be the AI-safety essay.
    </p>
  </Island>
</PageShell>
