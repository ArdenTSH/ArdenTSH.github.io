---
// CV (Phase 1.4). Rendered NATIVELY from the per-section Markdown files in
// src/content/cv/ — each section is its OWN island, ordered by frontmatter
// `order`. To update from a new CV, edit those files (see src/content/cv/_README.md).
// The PDF stays at public/cv/Arden_Tsang_CV.pdf as the formatted download.
import PageShell from "../layouts/PageShell.astro";
import Island from "../components/Island.astro";
import { Icon } from "astro-icon/components";
import { getCollection, render } from "astro:content";

const pdfPath = "/cv/Arden_Tsang_CV.pdf";
const sections = (await getCollection("cv")).sort((a, b) => a.data.order - b.data.order);
const rendered = await Promise.all(
  sections.map(async (s) => ({ title: s.data.title, Content: (await render(s)).Content })),
);
---

<PageShell title="CV" active="cv">
  <Island as="header">
    <p class="eyebrow">Curriculum vitae</p>
    <h1>CV</h1>
    <p class="lead">Read it in full below — or open the formatted PDF.</p>
    <p class="cv-actions">
      <a class="cv-action" href={pdfPath} target="_blank" rel="noopener">
        <Icon name="tabler:external-link" aria-hidden="true" /> Open PDF
      </a>
      <a class="cv-action" href={pdfPath} download>
        <Icon name="tabler:download" aria-hidden="true" /> Download
      </a>
    </p>
  </Island>

  {
    rendered.map(({ title, Content }) => (
      <Island as="section" class="cv-section">
        <h2>{title}</h2>
        <div class="prose cv-body"><Content /></div>
      </Island>
    ))
  }
</PageShell>

<style>
  .cv-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .cv-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .cv-action :global(svg) {
    width: 16px;
    height: 16px;
  }

  /* Each CV section is its own island; its h2 is the section title. */
  .cv-section h2 {
    font-size: var(--text-lg);
    font-weight: var(--weight-medium);
  }
  /* Section body (rendered Markdown -> styles target it via :global). */
  .cv-body :global(h3) {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    margin-top: var(--space-5);
  }
  .cv-body :global(h3:first-child),
  .cv-body :global(ul:first-child) {
    margin-top: 0;
  }
  /* The "meta" line — the paragraph immediately after an entry title. */
  .cv-body :global(h3 + p) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin-top: var(--space-1);
  }
  .cv-body :global(p) {
    margin-top: var(--space-3);
  }
  .cv-body :global(ul) {
    margin-top: var(--space-3);
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .cv-body :global(li) {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    max-width: var(--measure);
  }
  .cv-body :global(li)::marker {
    color: var(--text-faint);
  }
  .cv-body :global(strong) {
    color: var(--text-primary);
  }
</style>
