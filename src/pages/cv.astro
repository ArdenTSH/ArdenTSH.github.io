---
// CV (Phase 1.4). The CV is rendered NATIVELY — in the site's own type, as one
// scrolling document — from src/content/cv.md (edit that file to update it).
// The PDF stays at public/cv/Arden_Tsang_CV.pdf as the formatted download.
import PageShell from "../layouts/PageShell.astro";
import Island from "../components/Island.astro";
import { Icon } from "astro-icon/components";
import { Content as CV } from "../content/cv.md";

const pdfPath = "/cv/Arden_Tsang_CV.pdf";
---

<PageShell title="CV" active="cv">
  <Island as="header">
    <p class="eyebrow">Curriculum vitae</p>
    <h1>CV</h1>
    <p class="lead">Read it in full below — or open the formatted PDF.</p>
    <p class="cv-actions">
      <a class="cv-action" href={pdfPath} target="_blank" rel="noopener">
        <Icon name="tabler:external-link" aria-hidden="true" /> Open PDF
      </a>
      <a class="cv-action" href={pdfPath} download>
        <Icon name="tabler:download" aria-hidden="true" /> Download
      </a>
    </p>
  </Island>

  <Island variant="quiet">
    <div class="prose cv-body"><CV /></div>
  </Island>
</PageShell>

<style>
  .cv-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
  .cv-action {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .cv-action :global(svg) {
    width: 16px;
    height: 16px;
  }

  /* The CV reads as a document. Styles target the rendered Markdown, so they
     use :global() (Astro scoping doesn't reach <Content/>'s output). */
  .cv-body :global(h2) {
    font-size: var(--text-md);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    margin-top: var(--space-6);
    padding-bottom: var(--space-2);
    border-bottom: var(--hairline) solid var(--border-faint);
  }
  .cv-body :global(h2:first-child) {
    margin-top: 0;
  }
  .cv-body :global(h3) {
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    margin-top: var(--space-5);
  }
  /* The "meta" line — the paragraph immediately after an entry title. */
  .cv-body :global(h3 + p) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--text-muted);
    margin-top: var(--space-1);
  }
  .cv-body :global(p) {
    margin-top: var(--space-3);
  }
  .cv-body :global(ul) {
    margin-top: var(--space-3);
    padding-left: 1.15rem;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .cv-body :global(li) {
    color: var(--text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    max-width: var(--measure);
  }
  .cv-body :global(li)::marker {
    color: var(--text-faint);
  }
  .cv-body :global(strong) {
    color: var(--text-primary);
  }
</style>
