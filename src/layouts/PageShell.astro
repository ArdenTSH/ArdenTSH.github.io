---
// <PageShell> — the layout every page reuses (Phase 0.3).
// Layers, back to front: a fixed full-bleed background slot (pages inject their
// scene later), a single centred COLUMN of equal-width islands (all page content
// lives in islands — nothing loose floats on the background), an optional foot
// slot (the home MNIST strip lands there), and the persistent Dock on top.
import Layout from "./Layout.astro";
import Dock from "../components/Dock.astro";

interface Props {
  title: string;
  description?: string;
  active?: string;
}
const { title, description, active = "" } = Astro.props;
---

<Layout title={title} description={description}>
  <a class="skip-link" href="#main">Skip to content</a>

  {/* Full-bleed background slot — pages inject their scene here (Phase 3). */}
  <div class="bg-layer" aria-hidden="true"><slot name="background" /></div>

  <div class="page">
    {/* The island column: each top-level child is an island, all same width. */}
    <main id="main" tabindex="-1" class="column">
      <slot />
    </main>
    {/* Foot slot — the home MNIST strip lands here later. */}
    <div class="foot"><slot name="foot" /></div>
  </div>

  <Dock active={active} />
</Layout>

<style>
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: var(--z-background);
    background: var(--bg);
  }
  .page {
    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    /* clear the fixed bottom dock */
    padding-bottom: calc(var(--space-9) + env(safe-area-inset-bottom, 0px));
    /* Let pointer drags fall through the empty gaps to the background so the
       black hole is orbit-draggable; islands and links stay interactive. */
    pointer-events: none;
  }
  .page :where(a[href], button, input, textarea, select, label, summary, [tabindex], .island) {
    pointer-events: auto;
  }
  /* One centred column; every direct child (an island) is the same width. */
  .column {
    flex: 1 0 auto;
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  /* Programmatic focus target for the skip link — no visible ring needed here. */
  .column:focus {
    outline: none;
  }
  .foot:empty {
    display: none;
  }
  .foot {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--space-5);
    margin-top: var(--space-7);
  }
</style>

<script>
  // Curved "spherical" scroll (Phase 3.7): each island tilts toward a shared
  // horizon as you scroll and flattens as it passes the viewport centre — the
  // gentle feel of scrolling along the surface of a sphere. Disabled under
  // reduced-motion. Pure CSS transforms, so layout and scrolling are unaffected.
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const column = document.querySelector(".column");
  if (column && !reduceMotion.matches) {
    const items = Array.from(column.children) as HTMLElement[];
    const MAX_ANGLE = 18; // degrees of tilt toward the viewport edges (edit me to taste)
    let ticking = false;
    const apply = () => {
      const vh = window.innerHeight || 1;
      const mid = vh / 2;
      for (const el of items) {
        const rect = el.getBoundingClientRect();
        const centre = rect.top + rect.height / 2;
        const d = Math.max(-1, Math.min(1, (centre - mid) / vh)); // -1..1
        const angle = (-d * MAX_ANGLE).toFixed(2);
        const scale = (1 - Math.abs(d) * 0.04).toFixed(3);
        el.style.transform = `perspective(1500px) rotateX(${angle}deg) scale(${scale})`;
        el.style.opacity = (1 - Math.abs(d) * 0.18).toFixed(3);
      }
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    apply();
  }
</script>
