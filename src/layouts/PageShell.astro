---
// <PageShell> — the layout every page reuses (Phase 0.3).
// Layers, back to front: a fixed full-bleed background slot (pages inject their
// scene later), a single centred COLUMN of equal-width islands (all page content
// lives in islands — nothing loose floats on the background), an optional foot
// slot (the home MNIST strip lands there), and the persistent Dock on top.
import Layout from "./Layout.astro";
import Dock from "../components/Dock.astro";
import ModeToggle from "../components/ModeToggle.astro";
import LensGrid from "../components/LensGrid.astro";
import GridToggle from "../components/GridToggle.astro";
import ColliderControls from "../components/ColliderControls.astro";
import NeutrinoControls from "../components/NeutrinoControls.astro";

interface Props {
  title: string;
  description?: string;
  active?: string;
}
const { title, description, active = "" } = Astro.props;
---

<Layout title={title} description={description}>
  <a class="skip-link" href="#main">Skip to content</a>

  {/* Full-bleed background slot — pages inject their scene here (Phase 3). */}
  <div class="bg-layer" aria-hidden="true"><slot name="background" /></div>

  {/* Spacetime-lensing cursor grid (micro-motif): a mini-event that plays on the
      island you point at, behind its text. LensGrid re-parents one canvas into
      the hovered card, so it's site-wide and lives only on the islands. */}
  <LensGrid />

  <div class="page">
    {/* The island column: each top-level child is an island, all same width. */}
    <main id="main" tabindex="-1" class="column">
      <slot />
    </main>
    {/* Foot slot — the home MNIST strip lands here later. */}
    <div class="foot"><slot name="foot" /></div>
  </div>

  {/* Shrunk view: the whole page folds to this single tall bar on the far left,
      showing just the page title. data-island-expand steps it back up a level. */}
  <button class="page-spine" type="button" data-island-expand aria-label={`Restore ${title}`}>
    <span class="page-spine-bracket" aria-hidden="true">❯</span>
    <span class="page-spine-title">{title}</span>
  </button>

  <Dock active={active} />
  <ModeToggle />
  {/* Grid toggle removed from the UI — the spacetime grid is disabled in
      BlackHole.astro. Import + component kept so it's a one-line re-enable. */}
  {/* {active === "home" && <GridToggle />} */}
  {/* Collider controls: CV only (colour toggle + restart for the collision bg). */}
  {active === "cv" && <ColliderControls />}
  {/* Neutrino colour-coding control: research/neutrino only. */}
  {active === "neutrino" && <NeutrinoControls />}
</Layout>

<style>
  .bg-layer {
    position: fixed;
    inset: 0;
    z-index: var(--z-background);
    /* background-color (not the `background` shorthand) so the notebook grid
       background-image in global.css isn't reset. */
    background-color: var(--bg);
  }
  .page {
    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-direction: column;
    min-height: 100svh;
    /* clear the fixed bottom dock */
    padding-bottom: calc(var(--space-9) + env(safe-area-inset-bottom, 0px));
    /* Let pointer drags fall through the empty gaps to the background so the
       black hole is orbit-draggable; islands and links stay interactive. */
    pointer-events: none;
  }
  .page :where(a[href], button, input, textarea, select, label, summary, [tabindex], .island) {
    pointer-events: auto;
  }
  /* The island column. Same width for every child; centred by default, but on
     wide screens it shifts to the RIGHT (see the media query below) so the left
     of the viewport stays open for the background scene. */
  .column {
    flex: 1 0 auto;
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--space-5);
    padding-top: var(--space-8);
    display: flex;
    flex-direction: column;
    /* Roomier spacing between islands so the curved scroll plays out over more
       travel — you "cover more ground" per island. Bump to --space-9 for more. */
    gap: var(--space-8);
  }
  /* Programmatic focus target for the skip link — no visible ring needed here. */
  .column:focus {
    outline: none;
  }
  .foot:empty {
    display: none;
  }
  .foot {
    width: 100%;
    max-width: 48rem;
    margin-inline: auto;
    padding-inline: var(--space-5);
    margin-top: var(--space-7);
  }
  /* Wide screens: pin the column (and foot) to the LEFT, leaving the right of
     the viewport open for the background. Below 900px it stays centred — and
     the heavy background isn't loaded on small screens anyway. Tune the left
     gutter (--space-7) to move the islands closer to / further from the edge.
     (Swap to `auto var(--space-7)` to put them back on the right.) */
  @media (min-width: 900px) {
    .column,
    .foot {
      margin-inline: var(--space-7) auto;
    }
  }
</style>

<script>
  // Curved "spherical" scroll (Phase 3.7): each island tilts toward a shared
  // horizon as you scroll and flattens as it passes the viewport centre — the
  // gentle feel of scrolling along the surface of a sphere. Disabled under
  // reduced-motion. Pure CSS transforms, so layout and scrolling are unaffected.
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
  const column = document.querySelector(".column");
  if (column && !reduceMotion.matches) {
    const items = Array.from(column.children) as HTMLElement[];
    const MAX_ANGLE = 15; // tilt (deg) a SMALL island reaches near the viewport edge
    const PERSPECTIVE = 2400; // deeper than before → gentler foreshortening
    // An island this tall (px) gets the full tilt; TALLER islands tilt
    // proportionally LESS, so a big card never swings flat into the screen.
    const REF_HEIGHT = 380;
    let ticking = false;
    const apply = () => {
      // while the islands are resized (full / collapsed-to-side) the tilt is off —
      // a near-full reading panel shouldn't swing, and the single bar needn't either.
      if (document.documentElement.dataset.islands) {
        for (const el of items) { el.style.transform = ""; el.style.opacity = ""; }
        return;
      }
      const vh = window.innerHeight || 1;
      const mid = vh / 2;
      for (const el of items) {
        const rect = el.getBoundingClientRect();
        const centre = rect.top + rect.height / 2;
        const d = Math.max(-1, Math.min(1, (centre - mid) / vh)); // -1..1
        const damp = Math.min(1, REF_HEIGHT / Math.max(rect.height, 1));
        const angle = (-d * MAX_ANGLE * damp).toFixed(2);
        const scale = (1 - Math.abs(d) * 0.03).toFixed(3);
        el.style.transform = `perspective(${PERSPECTIVE}px) rotateX(${angle}deg) scale(${scale})`;
        el.style.opacity = (1 - Math.abs(d) * 0.14).toFixed(3);
      }
      ticking = false;
    };
    const onScroll = () => {
      if (!ticking) {
        ticking = true;
        requestAnimationFrame(apply);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll);
    apply();
  }
</script>
