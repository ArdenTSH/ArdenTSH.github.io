---
// Layout.astro — base HTML document. Default theme is NOTEBOOK (light/cream
// paper + ink); the mode toggle switches to the dark "real" (photoreal) view.
// The choice is persisted in localStorage under "bh-mode" ('notebook' | 'real')
// and applied before first paint by the inline script below (no flash).
import "../styles/global.css";
// Self-hosted webfonts (notebook type system). Fraunces = base serif voice;
// Rock Salt = the rough graphite TITLE face (notebook only); Mali = the pencil
// hand, kept around so it's a one-line swap (see --font-title in global.css).
import "@fontsource-variable/fraunces";
import "@fontsource/rock-salt";
import "@fontsource/mali/400.css";
import "@fontsource/mali/500.css";
import "@fontsource/mali/400-italic.css";
import "@fontsource/mali/500-italic.css";
// Ma Shan Zheng = a Chinese brush-handwriting face; via per-glyph fallback it
// only renders the CJK in the name (曾善蘅), Latin still uses Rock Salt.
import "@fontsource/ma-shan-zheng";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Arden Tsang — theoretical & computational physicist.",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="notebook">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    {/* Notebook (light/cream) is the default; the toggle switches to the dark "real" view. */}
    <meta name="color-scheme" content="light dark" />
    <meta name="generator" content={Astro.generator} />
    {/* Apply the saved view mode before first paint to avoid a flash. Default = notebook. */}
    <script is:inline>
      (function () {
        try {
          if ((localStorage.getItem("bh-mode") || "notebook") === "real") {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (e) {}
      })();
    </script>
    <title>{title}</title>
  </head>
  <body>
    {/* Graphite grain for notebook-mode titles + the .hand utility. Referenced
        from CSS as filter:url(#nb-graphite). Kept hidden and present on every
        page so the reference always resolves (a dangling filter ref would hide
        the text). Medium grain = light edge roughen + sparse stroke thinning. */}
    <svg aria-hidden="true" focusable="false" width="0" height="0" style="position:absolute;width:0;height:0;overflow:hidden">
      <filter id="nb-graphite" x="-7%" y="-12%" width="114%" height="124%" color-interpolation-filters="sRGB">
        <feTurbulence type="fractalNoise" baseFrequency="0.03" numOctaves="2" seed="6" result="w"></feTurbulence>
        <feDisplacementMap in="SourceGraphic" in2="w" scale="1.7" xChannelSelector="R" yChannelSelector="G" result="d"></feDisplacementMap>
        <feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="2" seed="8" result="g"></feTurbulence>
        <feComponentTransfer in="g" result="ga"><feFuncA type="table" tableValues="1 1 1 0.5 0.85 1 1 0.68 1 1"></feFuncA></feComponentTransfer>
        <feComposite in="d" in2="ga" operator="in"></feComposite>
      </filter>
    </svg>
    <slot />
  </body>
</html>
