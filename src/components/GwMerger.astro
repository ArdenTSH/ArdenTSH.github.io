---
// GwMerger — the signature intro: a binary BLACK-HOLE inspiral → merger → ringdown
// drawn as a physicist's sketch on the notebook grid, then a dive into the remnant.
// Two registers, deliberately: (1) the REAL metric — an equally-spaced dot lattice
// (graph paper) sheared by the true transverse-traceless QUADRUPOLAR strain h+/h×,
// evaluated at each dot's RETARDED time t−r/c so the wave propagates outward at finite
// speed with the chirp frozen into the shells; and (2) the kid-drawing layer — bold
// hand-drawn expanding wave-rings + a spiky "POW" explosion at merger. A slight
// stop-motion boil runs through the sketch and SMOOTHS OUT as the camera dives into
// the remnant (the drawing becoming real). Theme-matched (reads the live tokens), so
// it lands cleanly on whichever Home it precedes. Reduced-motion = one static frame.
// Hooks: window.gwReplay(), window.gwSeek(0..1). Removable with zero downstream effect.
---

<canvas class="gw-canvas" aria-hidden="true"></canvas>

<style>
  .gw-canvas { position: fixed; inset: 0; width: 100%; height: 100%; display: block; z-index: 250; pointer-events: none; }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>("canvas.gw-canvas");
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const TAU = Math.PI * 2;

    // ---- theme-matched palette (read the LIVE tokens; the intro adopts the page) --
    let bg = "#efe5cf", dotRest = "#9d9da6", dotBold = "#2b2b31", hole = "#2b2b31", wave = "#2b2b31", danger = "#a8442f", dark = false;
    const readColours = () => {};   // the SKETCH is always the cream notebook palette (theme-independent); the dive transitions to DARKBG

    // ---- timeline (ms) -----------------------------------------------------------
    const T = 10000;
    const P_I = 0.06, P_M = 0.29, P_DIVE = 0.38;  // inspiral-start / merger / dive-start; the dive is long & slow
    const tI = P_I * T, tM = P_M * T;
    const STEP = 1000 / 12;                        // stop-motion cadence (12 fps) for the sketch
    // ---- physics knobs (art-directed magnitudes, faithful FORM) ------------------
    const W_LO = 0.0028, W_HI = 0.0100, W_QNM = 0.0112;  // BOUNDED GW frequencies (rad/ms): keep the spiral wavelength > dot pitch (no aliasing)
    const TAU_RD = 240;                            // ringdown decay (ms)
    const C_ANIM = 0.95;                           // wave speed (px/ms) — finite propagation
    const FINAL_R = 0.204;                          // remnant ends at this fraction of min(W,H) — matched to the iframe BH's spin=0 shadow radius
    const DARKBG = "#06080d", STARCOL = "#c8d2e2";  // the dark space + stars the cream sketch dissolves into during the dive
    // RGB tuples + lerp helpers: the dive travels cream → dark space → cream, so the
    // background, grid, accretion and hole colours are all interpolated each frame.
    const RGB_BG = [239, 229, 207], RGB_DARK = [6, 8, 13], RGB_INK = [43, 43, 49], RGB_STAR = [200, 210, 226], RGB_VOID = [4, 5, 10];
    const c01 = (x: number) => (x < 0 ? 0 : x > 1 ? 1 : x);
    const mix = (a: number[], b: number[], t: number) => [a[0] + (b[0] - a[0]) * t, a[1] + (b[1] - a[1]) * t, a[2] + (b[2] - a[2]) * t];
    const rgb = (c: number[]) => "rgb(" + (c[0] | 0) + "," + (c[1] | 0) + "," + (c[2] | 0) + ")";
    const rgba = (c: number[], al: number) => "rgba(" + (c[0] | 0) + "," + (c[1] | 0) + "," + (c[2] | 0) + "," + al.toFixed(3) + ")";

    let W = 1, H = 1, dpr = 1, cx = 0, cy = 0, minWH = 1, pitch = 36, R0 = 150, A0 = 260, baseR = 30, GAIN = 1, DMAX = 28;
    let x0 = new Float32Array(0), y0 = new Float32Array(0), rr = new Float32Array(0), aa = new Float32Array(0);
    let N = 0;
    let stars: number[][] = [];   // far starfield revealed during the 3D dive: [sx, sy, brightness, size]
    let px3 = new Float32Array(0), py3 = new Float32Array(0), pin = new Uint8Array(0), gnx = 1, gny = 1;
    let fa = new Float32Array(0), gHalf = 1;   // per-vertex edge-fade (radial) so the lattice has no visible boundary
    let cax = 0, cay = 0, caz = 0, Fx = 0, Fy = 0, Fz = 1, Rx = 1, Ry = 0, Rz = 0, Ux = 0, Uy = 1, Uz = 0, foc3 = 1;  // 3D dive look-at camera

    const buildGrid = () => {
      pitch = Math.max(28, Math.min(44, minWH / 26));
      const coarse = window.matchMedia("(pointer: coarse)").matches;
      if (coarse) pitch *= 1.35;                   // cheaper on phones
      const halfW = W * 1.15, halfH = H * 1.15;     // the DOT lattice is near-field only; the infinite reach comes from drawDiveGrid's lines
      const nx = Math.ceil((2 * halfW) / pitch), ny = Math.ceil((2 * halfH) / pitch);
      N = nx * ny; gnx = nx; gny = ny;
      gHalf = Math.hypot(halfW, halfH);
      x0 = new Float32Array(N); y0 = new Float32Array(N); rr = new Float32Array(N); aa = new Float32Array(N); fa = new Float32Array(N);
      px3 = new Float32Array(N); py3 = new Float32Array(N); pin = new Uint8Array(N);
      const rF0 = gHalf * 0.45, rF1 = gHalf * 0.9;                // radial fade so the dot field has no hard edge (lines handle the far reach)
      let i = 0;
      for (let gy = 0; gy < ny; gy++) for (let gx = 0; gx < nx; gx++) {
        const x = -halfW + gx * pitch, y = -halfH + gy * pitch;   // world coords, origin = screen centre
        const r = Math.hypot(x, y);
        x0[i] = x; y0[i] = y; rr[i] = r; aa[i] = Math.atan2(y, x);
        let s = (rF1 - r) / (rF1 - rF0); s = s < 0 ? 0 : s > 1 ? 1 : s; fa[i] = s * s * (3 - 2 * s);   // smoothstep edge fade
        i++;
      }
    };
    const buildStars = () => {
      stars = [];
      const n = Math.round((W * H) / 9000);
      for (let s = 0; s < n; s++) stars.push([Math.random() * W, Math.random() * H, 0.3 + Math.random() * 0.7, Math.random() < 0.16 ? 1.7 : 1]);
    };
    const drawStars = (alpha: number) => {
      ctx.fillStyle = STARCOL;
      for (const s of stars) { ctx.globalAlpha = s[2] * alpha; ctx.fillRect(s[0], s[1], s[3], s[3]); }
      ctx.globalAlpha = 1;
    };

    // ---- the 3D dive: a perspective camera that ORBITS while it falls inward -------
    // (reuses the field-style yaw/pitch projection). The metric becomes a 3D grid of
    // LINES funnelling into the hole; the camera spirals in (BH stays centred, grows);
    // accretion fades in; it stops when the BH is the Home black hole's size.
    const setCam3 = (az: number, el: number, D: number) => {       // camera orbits the hole (az), descends (el), falls in (D); looks at origin
      cax = D * Math.cos(el) * Math.cos(az); cay = D * Math.sin(el); caz = D * Math.cos(el) * Math.sin(az);
      const fl = Math.hypot(cax, cay, caz) || 1; Fx = -cax / fl; Fy = -cay / fl; Fz = -caz / fl;
      const rl = Math.hypot(Fz, Fx) || 1; Rx = Fz / rl; Ry = 0; Rz = -Fx / rl;
      Ux = Fy * Rz - Fz * Ry; Uy = Fz * Rx - Fx * Rz; Uz = Fx * Ry - Fy * Rx;
      foc3 = minWH * 0.92;
    };
    const proj3 = (X: number, Y: number, Z: number) => {
      const ex = X - cax, ey = Y - cay, ez = Z - caz, cz = ex * Fx + ey * Fy + ez * Fz, s = foc3 / cz;
      return [cx + (ex * Rx + ey * Ry + ez * Rz) * s, cy - (ex * Ux + ey * Uy + ez * Uz) * s, cz];
    };
    // a point on the warped spacetime sheet: a flat (x,z) lattice that DIPS in −Y near the
    // mass — a bounded well, depth → DEPTH at the centre, ~1/r far out (flat at ∞). No
    // in-plane pull, so the sheet stays a clean rubber-sheet funnel (no converging spray).
    const projPlane = (wx: number, wz: number, DEPTH: number, rwf: number) => {
      const r = Math.hypot(wx, wz);
      return proj3(wx, -DEPTH * (rwf / (r + rwf)), wz);
    };
    // LINE positions: UNIFORM `pitch` spacing so the grid density is ISOTROPIC — equal
    // along the axes and the diagonals (a geometric tail on the positions would blow up
    // the spacing in BOTH coords at once → sparse diagonals). A short geometric tail adds
    // only the handful of FAR lines needed to reach the horizon (those bunch into the
    // cream wash anyway, so their sparseness never shows).
    const LML = 72;                                                  // uniform lines each side (the graph paper)
    const linePos = (m: number) => {
      const a = Math.abs(m), s = m < 0 ? -1 : 1;
      return a <= LML ? s * a * pitch : s * pitch * (LML + (Math.pow(1.9, a - LML) - 1) / 0.9);
    };
    const LKMAX = LML + 8;
    // SAMPLE positions ALONG each line: dense (uniform) through the curved well, then
    // geometric out to ∞. The far field is straight, so a few points suffice — this is
    // where we economise, NOT on the line count, so density stays isotropic but cheap.
    const SM0 = 18;
    const samplePos = (n: number) => {
      const a = Math.abs(n), s = n < 0 ? -1 : 1;
      return a <= SM0 ? s * a * pitch : s * pitch * (SM0 + (Math.pow(1.8, a - SM0) - 1) / 0.8);
    };
    const SKMAX = SM0 + 9;
    const drawDiveGrid = (DEPTH: number, rwf: number, bhR: number, alpha: number) => {
      if (alpha <= 0.01) return;
      const near = minWH * 0.04, hole2 = bhR * 0.92, rMin = pitch * 0.7;   // rMin: drop the singular throat (BH caps the centre)
      ctx.strokeStyle = rgb(RGB_INK); ctx.lineWidth = 1.0; ctx.lineCap = "round"; ctx.lineJoin = "round"; ctx.globalAlpha = alpha;
      for (let fam = 0; fam < 2; fam++) {                            // two families of lines (constant-X, constant-Z)
        for (let m = -LKMAX; m <= LKMAX; m++) {
          const fixed = linePos(m);
          ctx.beginPath();
          let started = false;
          for (let n = -SKMAX; n <= SKMAX; n++) {                    // walk the line across the plane to ∞
            const free = samplePos(n);
            if (Math.hypot(fixed, free) < rMin) { started = false; continue; }
            const pr = fam === 0 ? projPlane(fixed, free, DEPTH, rwf) : projPlane(free, fixed, DEPTH, rwf);
            if (pr[2] < near || Math.hypot(pr[0] - cx, pr[1] - cy) < hole2) { started = false; continue; }
            if (!started) { ctx.moveTo(pr[0], pr[1]); started = true; } else ctx.lineTo(pr[0], pr[1]);
          }
          ctx.stroke();
        }
      }
      ctx.globalAlpha = 1;
    };
    // accretion = HAND-DRAWN orbital paths: one tilted ellipse around the hole, then
    // another, accelerating until many overlap into a sketched disk. They're inked the
    // same colour as the grid (light in space → graphite on cream) so they settle into
    // the cream Home black hole as the dive lands.
    const drawAccretion = (bhR: number, el: number, prog: number, col: string, alpha: number) => {
      const MAXN = 22;
      const n = Math.floor(prog * prog * MAXN);                     // accelerating: a ring or two early, many by the end
      if (n < 1) return;
      const sq = Math.max(0.16, Math.sin(el));                      // orbital tilt → each ring reads as an ellipse seen edge-on
      ctx.save(); ctx.translate(cx, cy); ctx.scale(1, sq);
      ctx.lineCap = "round"; ctx.lineJoin = "round";
      const baseLw = Math.max(1, bhR * 0.028);
      for (let k = 0; k < n; k++) {
        const f = k / MAXN;
        const rad = bhR * (1.18 + f * 2.05);                        // successive orbits step outward → the disk thickens
        const a = alpha * (0.62 - 0.42 * f);
        if (a <= 0.01) continue;
        ctx.globalAlpha = a; ctx.strokeStyle = col; ctx.lineWidth = baseLw * (1 - 0.45 * f);
        ctx.beginPath();
        const seg = 30, seed = k * 23.1, rot = hash(seed, k) * 0.3;
        for (let i = 0; i <= seg; i++) {
          const th = (i / seg) * TAU + rot, rj = rad * (1 + hash(seed + i, rad) * 0.05);
          const x = Math.cos(th) * rj, y = Math.sin(th) * rj;
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.stroke();
      }
      ctx.restore(); ctx.globalAlpha = 1;
    };
    const render3D = (t: number, p: number) => {
      const dp = (p - P_DIVE) / (1 - P_DIVE);                        // 0..1 across the long, slow dive — STAYS CREAM throughout
      const lg = ease(c01((dp - 0.02) / 0.16));                      // the lines draw in once the dots are set
      const dotEarly = 1 - ease(c01((dp - 0.20) / 0.20));           // dots stay FULL, then fade only AFTER the lines are made
      const dv = ease(c01((dp - 0.06) / 0.80));                      // the camera's long, slow fall-in

      const remW = baseR * 1.6 * Math.cbrt(mTot);
      const el = 1.32 - dv * 1.02, yaw = dv * 1.7, D = minWH * (1.05 - dv * 0.80);   // top-down → grazing; orbit; fall in
      setCam3(yaw, el, D);
      const DEPTH = (0.05 + 0.6 * dv) * minWH, rwf = 0.34 * minWH, near = minWH * 0.04;  // the well deepens as we fall in
      const bhR = remW + (FINAL_R * minWH - remW) * dv, rMin = pitch * 0.9;

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = rgb(RGB_BG); ctx.fillRect(0, 0, W, H);          // ALWAYS cream — no dark interlude

      // (i) the metric dots (near field), full until the lines are made, then fade — leaving the line grid
      if (dotEarly > 0.01) {
        ctx.fillStyle = rgb(RGB_INK);
        for (let i = 0; i < N; i++) {
          const r = rr[i];
          if (r < rMin) continue;
          const pr = projPlane(x0[i], y0[i], DEPTH, rwf);
          if (pr[2] < near || Math.hypot(pr[0] - cx, pr[1] - cy) < bhR * 0.95) continue;
          ctx.globalAlpha = dotEarly * fa[i]; ctx.fillRect(pr[0] - 1, pr[1] - 1, 2, 2);
        }
        ctx.globalAlpha = 1;
      }

      // (ii) the infinite line grid — funnels into the hole and runs off to the horizon
      drawDiveGrid(DEPTH, rwf, bhR, 0.5 * lg);

      // (iii) horizon wash: cream fades in where the lines converge, so they never show an
      // end — they just recede forever. Project a far plane point to find the horizon line.
      const fh = Math.hypot(Fx, Fz) || 1;
      const hp = projPlane(Fx / fh * 400 * minWH, Fz / fh * 400 * minWH, DEPTH, rwf);
      if (hp[2] > near) {
        const horizonY = hp[1], band = H * 0.2, y1 = horizonY + band;
        if (y1 > 0) {
          const grad = ctx.createLinearGradient(0, horizonY - 2, 0, y1);
          grad.addColorStop(0, rgba(RGB_BG, 1)); grad.addColorStop(1, rgba(RGB_BG, 0));
          ctx.fillStyle = grad; ctx.fillRect(0, 0, W, y1);
        }
      }

      // (iv) the hole — a plain black ball: a PERFECT centred circle. The iframe BH is
      // loaded spin=0 (also a perfect centred circle of the same radius), so the crossfade
      // is circle → circle with no shape change. (The old edge "re-ink" wobble read as a
      // crooked BH mid-handoff — removed; spin=0 already matches the sketch shape.)
      ctx.fillStyle = rgb(RGB_INK); ctx.beginPath(); ctx.arc(cx, cy, bhR, 0, TAU); ctx.fill();

      canvas.style.opacity = String(1 - ease(c01((p - 0.92) / 0.07)));  // cross-fade out → reveal the cream sketch BH iframe behind
      if (!diving) { diving = true; try { window.dispatchEvent(new CustomEvent("gw:diving")); } catch (e) {} }
      // tell the BH iframe to un-pause ~0.7s before the crossfade so it's warm & rendering
      if (p >= 0.85 && !revealSoonFired) { revealSoonFired = true; try { window.dispatchEvent(new CustomEvent("gw:reveal-soon")); } catch (e) {} }
      if (p >= 0.985 && !doneFired) { doneFired = true; try { window.dispatchEvent(new CustomEvent("gw:done")); } catch (e) {} }
    };

    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth; H = canvas.clientHeight; minWH = Math.min(W, H);
      canvas.width = Math.max(1, Math.round(W * dpr)); canvas.height = Math.max(1, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cx = W / 2; cy = H / 2;
      R0 = 0.17 * minWH; A0 = 0.30 * minWH; baseR = 0.022 * minWH; GAIN = 1.7;
      buildGrid(); buildStars();
      DMAX = 1.2 * pitch;                                           // cap each dot's GW displacement (strong shear, still coherent)
    };

    // ---- closed-form source: orbital phase + radiated amplitude at any time -------
    const orbU = (tt: number) => Math.max(0, Math.min(1, (tM - tt) / (tM - tI)));   // 1 at inspiral start → 0 at merger
    // bounded chirp: orbital frequency rises W_LO→W_HI through the inspiral, then a
    // fixed ringdown rate — capped so the wave's spatial wavelength stays > dot pitch.
    const omega = (tt: number) => {
      if (tt < tI) return W_LO;
      if (tt <= tM) return W_LO + (W_HI - W_LO) * Math.pow(1 - orbU(tt), 1.6);
      return W_QNM;
    };
    const LUT_DT = 4;                                                // integrate the phase ONCE into a LUT; retarded lookup is then O(1)
    const phiLut = new Float32Array(Math.ceil((T + 400) / LUT_DT) + 2);
    (() => { let phi = 0; for (let i = 0; i < phiLut.length; i++) { phiLut[i] = phi; phi += omega(i * LUT_DT) * LUT_DT; } })();
    const PhiAt = (tt: number) => {
      if (tt <= 0) return tt * W_LO;
      const f = tt / LUT_DT, i = f | 0;
      if (i >= phiLut.length - 1) return phiLut[phiLut.length - 1];
      return phiLut[i] + (phiLut[i + 1] - phiLut[i]) * (f - i);
    };
    const AmpAt = (tt: number) => {
      if (tt < tI) return 0;                                          // negligible radiation before inspiral
      if (tt <= tM) { const u = orbU(tt); return 0.18 + 0.82 * (1 - u) * (1 - u); } // rises into merger
      return Math.exp(-(tt - tM) / TAU_RD);                          // ringdown burst decays
    };
    const sep = (tt: number) => (tt < tI ? A0 : A0 * Math.pow(orbU(tt), 0.25));     // separation shrinks to 0 at merger

    // bodies at sim-time: two discs (inspiral) or one remnant (post-merger, settling)
    const mass1 = 1.0, mass2 = 0.78, mTot = mass1 + mass2;
    const bodies = (tt: number): number[][] => {
      if (tt >= tM) {
        const s = Math.min(1, (tt - tM) / 240);                      // remnant settles to its size
        return [[0, 0, baseR * (1.5 + 0.3 * (1 - s)) * Math.cbrt(mTot)]];
      }
      const a = sep(tt), th = PhiAt(tt);
      const c = Math.cos(th), sN = Math.sin(th);
      return [
        [(mass2 / mTot) * a * c, (mass2 / mTot) * a * sN, baseR * Math.cbrt(mass1)],
        [-(mass1 / mTot) * a * c, -(mass1 / mTot) * a * sN, baseR * Math.cbrt(mass2)],
      ];
    };

    // ---- the GW strain displacement of a single dot (TT gauge, retarded) ---------
    // ψ = 2φ_src − 2Φ(t_ret): source illumination. The +/× basis is SCREEN-FIXED, so
    // the pattern is a rotating cross that propagates outward — never radial breathing.
    const STR = { dx: 0, dy: 0, m: 0 };
    const strain = (i: number, eT: number) => {
      const r = rr[i], ts = eT - r / C_ANIM, amp = AmpAt(ts);
      if (amp < 0.012) { STR.dx = 0; STR.dy = 0; STR.m = 0; return; }
      const A = amp * (R0 / (r + R0));                               // softened falloff (bounds far-dot motion)
      const psi = 2 * aa[i] - 2 * PhiAt(ts);
      const hp = A * Math.cos(psi), hx = A * Math.sin(psi), x = x0[i], y = y0[i];
      STR.dx = 0.5 * (hp * x + hx * y) * GAIN;
      STR.dy = 0.5 * (hx * x - hp * y) * GAIN;
      const mg = Math.hypot(STR.dx, STR.dy);                        // cap displacement < pitch so dots never cross into noise
      if (mg > DMAX) { const k = DMAX / mg; STR.dx *= k; STR.dy *= k; }
      STR.m = A;
    };

    // ---- hand-drawn helpers (boil = per-step jitter; the sketch shivers) ----------
    const hash = (a: number, b: number) => { const s = Math.sin(a * 127.1 + b * 311.7) * 43758.5; return s - Math.floor(s) - 0.5; };
    const handCircle = (px: number, py: number, rad: number, lw: number, col: string, alpha: number, seed: number, jit: number) => {
      ctx.globalAlpha = alpha; ctx.strokeStyle = col; ctx.lineWidth = lw; ctx.lineJoin = "round"; ctx.lineCap = "round";
      ctx.beginPath();
      const seg = 26;
      for (let i = 0; i <= seg; i++) {
        const t = (i / seg) * TAU, rj = rad * (1 + hash(seed + i, rad) * jit);
        const x = px + Math.cos(t) * rj, y = py + Math.sin(t) * rj;
        i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
      }
      ctx.stroke(); ctx.globalAlpha = 1;
    };
    // a kid's comic explosion: a spiky star, jagged lightning bolts, + flung debris
    const explosion = (px: number, py: number, rad: number, prog: number, seed: number) => {
      const fade = Math.max(0, 1 - prog);
      ctx.lineCap = "round"; ctx.lineJoin = "round";
      for (let pass = 0; pass < 2; pass++) {                        // the spiky star, varied spike lengths, gone over twice
        ctx.globalAlpha = (0.9 - 0.3 * pass) * fade; ctx.strokeStyle = wave; ctx.lineWidth = (2.6 - pass) * (minWH / 900);
        ctx.beginPath();
        const spikes = 13;
        for (let i = 0; i <= spikes * 2; i++) {
          const t = (i / (spikes * 2)) * TAU, out = i % 2 === 0;
          const base = out ? rad * (0.7 + Math.abs(hash(seed + i, i)) * 1.0) : rad * 0.4;
          const rj = base * (0.45 + prog);
          const x = px + Math.cos(t) * rj, y = py + Math.sin(t) * rj;
          i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
        }
        ctx.closePath(); ctx.stroke();
      }
      ctx.globalAlpha = 0.85 * fade; ctx.lineWidth = 2 * (minWH / 900);   // zig-zag lightning bolts shooting out
      for (let b = 0; b < 6; b++) {
        const a = (b / 6) * TAU + hash(seed + b, b) * 0.5, len = rad * (1.1 + Math.abs(hash(seed + b * 7, b)) * 0.8) * (0.5 + prog);
        ctx.beginPath(); ctx.moveTo(px + Math.cos(a) * rad * 0.5, py + Math.sin(a) * rad * 0.5);
        for (let s = 1; s <= 3; s++) {
          const rr2 = rad * 0.5 + (len - rad * 0.5) * s / 3, off = (s % 2 ? 1 : -1) * rad * 0.13 * (1 + hash(seed + b + s, s));
          ctx.lineTo(px + Math.cos(a) * rr2 + Math.cos(a + 1.57) * off, py + Math.sin(a) * rr2 + Math.sin(a + 1.57) * off);
        }
        ctx.stroke();
      }
      ctx.globalAlpha = 0.7 * fade * prog;                         // little debris bits flung outward (tiny curved marks)
      for (let d = 0; d < 9; d++) {
        const a = hash(seed + d * 3, d) * TAU, dist = rad * (1.1 + Math.abs(hash(seed + d, d)) * 0.9) * prog;
        ctx.beginPath(); ctx.arc(px + Math.cos(a) * dist, py + Math.sin(a) * dist, rad * 0.1, a, a + 2.3); ctx.stroke();
      }
      ctx.globalAlpha = 1;
    };

    // ---- the two trailing GW spiral arms (layer 1) + the black-hole blobs --------
    const handBlob = (px: number, py: number, rad: number, col: string, seed: number) => {
      ctx.fillStyle = col; ctx.beginPath();
      const seg = 22;
      for (let i = 0; i <= seg; i++) { const t = (i / seg) * TAU, rj = rad * (1 + hash(seed + i, rad) * 0.06); const x = px + Math.cos(t) * rj, y = py + Math.sin(t) * rj; i === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y); }
      ctx.closePath(); ctx.fill();
    };
    // each black hole trails its OWN spiral arm; the two arms are π apart, so neither
    // crosses the other hole. A crest follows φ = Φ(t_ret) + armOffset, winding outward
    // to the wavefront radius (eT−tI)·C — the rotating two-arm quadrupole, drawn by hand.
    const drawSpirals = (eT: number, seed: number) => {
      const rWave = (eT - tI) * C_ANIM;
      if (rWave < 10) return;
      const rEnd = Math.min(rWave, Math.hypot(W, H) * 0.64);
      const a = sep(eT), merged = eT >= tM, rc = baseR * 1.6 * Math.cbrt(mTot);
      const arms = merged ? [[0, rc], [Math.PI, rc]] : [[0, (mass2 / mTot) * a], [Math.PI, (mass1 / mTot) * a]];
      ctx.lineCap = "round"; ctx.lineJoin = "round";
      const lw = 2.6 * (minWH / 900);
      for (const [off, rStart] of arms) {
        let px = 0, py = 0, have = false;
        for (let r = Math.max(rStart, 6); r <= rEnd; r += 6) {
          const ts = eT - r / C_ANIM, amp = AmpAt(ts);
          if (amp < 0.02) { have = false; continue; }              // wave hasn't reached here / has faded
          const phi = PhiAt(ts) + off, rj = r * (1 + hash(seed * 3 + r, off) * 0.018);
          const x = Math.cos(phi) * rj, y = Math.sin(phi) * rj;
          if (have) {
            ctx.globalAlpha = Math.min(0.72, amp * 0.95) * (1 - 0.3 * r / (rEnd + 1));
            ctx.strokeStyle = wave; ctx.lineWidth = lw;
            ctx.beginPath(); ctx.moveTo(px, py); ctx.lineTo(x, y); ctx.stroke();
          }
          px = x; py = y; have = true;
        }
      }
      ctx.globalAlpha = 1;
    };

    // ---- one frame ---------------------------------------------------------------
    const ease = (t: number) => 1 - Math.pow(1 - t, 3);
    const render = (t: number) => {
      const p = t / T;
      if (p >= P_DIVE) { render3D(t, p); return; }                  // the dive is a 3D orbiting fall-in (separate path)
      const stop = true;
      const eT = Math.floor(t / STEP) * STEP;                       // stop-motion through the sketch
      const seed = Math.floor((stop ? t : 0) / STEP);              // boil seed (frozen during the smooth dive)
      const cl = (a: number, b: number) => Math.min(1, Math.max(0, (p - a) / (b - a)));

      // the 3D dive: cream → dark space, the grid recedes & dissolves into a starfield,
      // and the camera zooms into the remnant until it's the Home black hole's size.
      const darken = cl(0.63, 0.80), gridA = 1 - cl(0.66, 0.83), starA = cl(0.68, 0.90);
      let Z = 1;
      if (p >= P_DIVE) {
        const remW = baseR * 1.6 * Math.cbrt(mTot), zEnd = (FINAL_R * minWH) / remW;
        Z = 1 + (zEnd - 1) * ease(cl(P_DIVE, 0.93));
      }

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      ctx.fillStyle = bg; ctx.fillRect(0, 0, W, H);
      if (darken > 0) { ctx.globalAlpha = darken; ctx.fillStyle = DARKBG; ctx.fillRect(0, 0, W, H); ctx.globalAlpha = 1; }
      if (starA > 0) drawStars(starA);                              // far starfield behind everything
      ctx.save();
      ctx.translate(cx, cy); ctx.scale(Z, Z);                       // world origin = screen centre

      const bod = bodies(eT);
      // (1) the metric: dots displaced by curvature wells + GW strain (fades out into the starfield on the dive)
      const fadeIn = Math.min(1, t / 220);                          // grid eases in quickly, early
      if (gridA > 0.01) for (let i = 0; i < N; i++) {
        strain(i, eT);
        let dx = STR.dx, dy = STR.dy;
        // curvature wells: STEEP & DENSE near each black hole — the grid dives in
        for (const b of bod) {
          const ex = x0[i] - b[0], ey = y0[i] - b[1], d2 = ex * ex + ey * ey, bw2 = b[2] * b[2] * 13;
          const g = Math.min(0.82, 1.3 * bw2 / (d2 + bw2 * 0.22));
          dx -= ex * g; dy -= ey * g;
        }
        const wx = x0[i] + dx, wy = y0[i] + dy;
        let hidden = false;
        for (const b of bod) { const ex = wx - b[0], ey = wy - b[1]; if (ex * ex + ey * ey < b[2] * b[2] * 0.92) { hidden = true; break; } }
        if (hidden) continue;
        const m = STR.m;
        ctx.globalAlpha = (0.45 + Math.min(0.55, m * 6)) * fadeIn * gridA;
        ctx.fillStyle = m > 0.04 ? wave : dotRest;
        const s = (1.0 + Math.min(1.9, m * 13)) / Z;                // strained dots bolden; ~constant px through the zoom
        ctx.fillRect(wx - s / 2, wy - s / 2, s, s);
      }
      ctx.globalAlpha = 1;

      // (2a) the two trailing GW spiral arms (the drawn layer)
      drawSpirals(eT, seed);

      // black holes: hand-drawn dark blobs, no rim (boiling)
      for (const b of bod) handBlob(b[0], b[1], b[2], hole, seed * 7 + (b[0] | 0));

      // (2b) the merger explosion — a comic POW: spiky star + bolts + flung debris
      const burst = (eT - tM);
      if (burst >= -STEP && burst < 460) {
        const prog = Math.max(0, Math.min(1, burst / 460));
        explosion(0, 0, baseR * 4.8 * Math.cbrt(mTot), prog, seed * 13);
      }
      ctx.restore();

      // reveal: fade the whole sketch canvas out over the dark, star-filled frame, uncovering
      // the real photoreal black-hole iframe behind it (texture + rotation + accretion).
      canvas.style.opacity = String(1 - ease(cl(0.88, 0.99)));
      if (p >= P_DIVE && !diving) { diving = true; try { window.dispatchEvent(new CustomEvent("gw:diving")); } catch (e) {} }
      if (p >= 0.985 && !doneFired) { doneFired = true; try { window.dispatchEvent(new CustomEvent("gw:done")); } catch (e) {} }
    };

    // ---- lifecycle ---------------------------------------------------------------
    let t = 0, last = 0, raf = 0, playing = false, diving = false, doneFired = false, revealSoonFired = false;
    const frame = (now: number) => {
      const dt = Math.min(now - last, 50); last = now;
      t += dt;
      if (t >= T) { t = T; render(t); playing = false; return; }   // hold the final frame; replay restarts
      render(t);
      raf = requestAnimationFrame(frame);
    };
    const play = () => { if (playing) return; playing = true; diving = false; doneFired = false; revealSoonFired = false; canvas.style.opacity = "1"; try { window.dispatchEvent(new CustomEvent("gw:reset")); } catch (e) {} t = 0; last = performance.now(); cancelAnimationFrame(raf); raf = requestAnimationFrame(frame); };
    const staticFrame = () => render(tM + 2 * TAU_RD);

    resize();
    window.addEventListener("resize", () => { resize(); if (!playing) (reduce.matches ? staticFrame() : render(t)); });
    new MutationObserver(() => { readColours(); if (!playing) (reduce.matches ? staticFrame() : render(t)); })
      .observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    (window as any).gwReplay = () => { canvas.style.display = "block"; if (reduce.matches) { staticFrame(); return; } play(); };
    (window as any).gwSeek = (p: number) => { cancelAnimationFrame(raf); playing = false; t = Math.max(0, Math.min(1, p)) * T; render(t); };

    if (document.documentElement.classList.contains("gw-off")) { canvas.style.display = "none"; }  // home, intro already seen → don't run
    else if (reduce.matches) staticFrame();
    else play();
  }
</script>
