---
// Accreting black-hole home background (Phase 3.5).
// Vendored MIT renderer (Adriwin06/black-hole, a fork of oseiskar/black-hole) in
// public/blackhole/ — see public/blackhole/LICENSE and COPYRIGHT.md for credit.
// The one non-MIT asset (the Milky-Way sky) was replaced with a procedurally
// generated CC0 starfield, so the whole thing is redistributable.
//
// Loaded — and made interactive (drag the empty margins to orbit) — on DESKTOP
// only, and skipped under reduced-motion, to protect mobile performance and
// accessibility. Elsewhere the page simply shows its plain dark background.
---

<iframe
  class="bh-bg"
  data-src="/blackhole/index.html"
  title=""
  aria-hidden="true"
  tabindex="-1"
  scrolling="no"></iframe>

<script>
  const frame = document.querySelector<HTMLIFrameElement>("iframe.bh-bg");
  const wide = window.matchMedia("(min-width: 900px)");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
  // Default view is the notebook (sketch); the "real" mode loads photoreal.
  let mode = "notebook";
  try { mode = localStorage.getItem("bh-mode") || "notebook"; } catch (e) {}
  const style = mode === "real" ? "photoreal" : "sketch";
  // The lensed graph-paper grid (sketch only) can be toggled off and is persisted.
  let gridOn = true;
  try { gridOn = (localStorage.getItem("bh-grid") || "on") !== "off"; } catch (e) {}
  if (frame && frame.dataset.src && wide.matches && !reduce.matches) {
    frame.src = frame.dataset.src + "?style=" + style + "&grid=" + (gridOn ? "1" : "0");
  }

  // Live style toggle from the parent page (iframe is same-origin).
  // A site button can call:  window.bhSetStyle('sketch') / window.bhSetStyle('photoreal')
  (window as any).bhSetStyle = (style: "sketch" | "photoreal") => {
    if (!frame || !frame.contentWindow) return;
    const w = frame.contentWindow as any;
    if (typeof w.blackHoleSetStyle === "function") w.blackHoleSetStyle(style);
    else frame.contentWindow.postMessage({ type: "bh:setStyle", style }, location.origin);
  };

  // Live grid toggle from the parent page.
  // A site button can call:  window.bhSetGrid(true) / window.bhSetGrid(false)
  (window as any).bhSetGrid = (on: boolean) => {
    if (!frame || !frame.contentWindow) return;
    const w = frame.contentWindow as any;
    if (typeof w.blackHoleSetGrid === "function") w.blackHoleSetGrid(on);
    else frame.contentWindow.postMessage({ type: "bh:setGrid", on }, location.origin);
  };
</script>

<style>
  .bh-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    /* Interactive: visitors drag the empty margins to orbit the black hole. */
    pointer-events: auto;
  }
</style>
