---
// Accreting black-hole home background (Phase 3.5).
// Vendored MIT renderer (Adriwin06/black-hole, a fork of oseiskar/black-hole) in
// public/blackhole/ — see public/blackhole/LICENSE and COPYRIGHT.md for credit.
// The one non-MIT asset (the Milky-Way sky) was replaced with a procedurally
// generated CC0 starfield, so the whole thing is redistributable.
//
// Loaded — and made interactive (drag the empty margins to orbit) — on DESKTOP
// only, and skipped under reduced-motion, to protect mobile performance and
// accessibility. Elsewhere the page simply shows its plain dark background.
---

<iframe
  class="bh-bg"
  data-src="/blackhole/index.html"
  title=""
  aria-hidden="true"
  tabindex="-1"
  scrolling="no"></iframe>

<script>
  import { revealStaged } from "../scripts/bhReveal";
  const frame = document.querySelector<HTMLIFrameElement>("iframe.bh-bg");
  const wide = window.matchMedia("(min-width: 900px)");
  const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
  // Default view is the notebook (sketch); the "real" mode loads photoreal.
  let mode = "notebook";
  try { mode = localStorage.getItem("bh-mode") || "notebook"; } catch (e) {}
  const style = mode === "real" ? "photoreal" : "sketch";
  // The lensed graph-paper grid (sketch only) — the "fabric of spacetime" sketch —
  // is DISABLED site-wide for now: kept in code, just not shown. The read + the
  // bhSetGrid hook below stay intact, so re-enabling is just deleting the override
  // here and restoring the GridToggle render in PageShell.astro.
  let gridOn = true;
  try { gridOn = (localStorage.getItem("bh-grid") || "on") !== "off"; } catch (e) {}
  gridOn = false;   // disabled: never render the spacetime grid
  // First-visit Home: the GW intro is playing (gw-intro class set pre-paint). Load the
  // BH BARE (disk/stars/sky off) so the dive can land on the lone sphere, then stage
  // them in via window.bhRevealStaged() (called from PageShell on gw:done).
  const staged = document.documentElement.classList.contains("gw-intro");
  if (frame && frame.dataset.src && wide.matches && !reduce.matches) {
    // perf=bg pins a cheap tier + caps DPR (this is a decorative NPR background).
    frame.src = frame.dataset.src + "?style=" + style + "&grid=" + (gridOn ? "1" : "0") + "&perf=bg" + (staged ? "&reveal=staged" : "");
  }

  // Staged handoff driver: fade in accretion, then stars + sky; tell the page when done.
  (window as any).bhRevealStaged = () => revealStaged(frame, {
    onDone: () => { try { window.dispatchEvent(new CustomEvent("bh:reveal-done")); } catch (e) {} },
  });

  // ── Perf + replay ────────────────────────────────────────────────────────────
  // Pause the heavy ray-tracer whenever it can't be seen — (a) off-screen, (b) tab
  // hidden, or (c) during the intro it's hidden behind the opaque dive canvas (warm
  // ~2s, then pause until gw:reveal-soon). And reset the BH to BARE on gw:reset so a
  // (re)played dive lands on the clean sphere. Resume is instant (the RAF stays alive).
  const setPaused = (p: boolean) => {
    const w = frame?.contentWindow as any;
    if (w && typeof w.blackHoleSetPaused === "function") w.blackHoleSetPaused(p);
    else w?.postMessage({ type: "bh:setPaused", paused: p }, location.origin);
  };
  const setLook = (o: Record<string, number>) => {
    const w = frame?.contentWindow as any;
    if (w && typeof w.blackHoleSetLook === "function") w.blackHoleSetLook(o);
    else w?.postMessage({ type: "bh:setLook", look: o }, location.origin);
  };
  const resetBare = () => setLook({ disk_gain: 1, disk_reveal_r: -0.1, star_gain: 0, galaxy_gain: 0, spin: 0 });
  (window as any).bhResetStaged = resetBare;   // used by the Home replay button
  if (frame && wide.matches && !reduce.matches) {
    let onScreen = true, introHold = staged, warmed = !staged;
    const sync = () => { if (warmed) setPaused(!onScreen || document.hidden || introHold); };
    if ("IntersectionObserver" in window) {
      new IntersectionObserver((e) => { onScreen = e[0].isIntersecting; sync(); }, { threshold: 0.01 }).observe(frame);
    }
    document.addEventListener("visibilitychange", sync);
    // intro / replay: hold paused (hidden behind the dive), resume just before the crossfade
    window.addEventListener("gw:reveal-soon", () => { introHold = false; sync(); });
    window.addEventListener("gw:done", () => { introHold = false; sync(); });
    window.addEventListener("gw:reset", () => { introHold = true; sync(); resetBare(); });
    if (staged) setTimeout(() => { warmed = true; sync(); }, 2200);
    else sync();
  }

  // Live style toggle from the parent page (iframe is same-origin).
  // A site button can call:  window.bhSetStyle('sketch') / window.bhSetStyle('photoreal')
  (window as any).bhSetStyle = (style: "sketch" | "photoreal") => {
    if (!frame || !frame.contentWindow) return;
    const w = frame.contentWindow as any;
    if (typeof w.blackHoleSetStyle === "function") w.blackHoleSetStyle(style);
    else frame.contentWindow.postMessage({ type: "bh:setStyle", style }, location.origin);
  };

  // Live grid toggle from the parent page.
  // A site button can call:  window.bhSetGrid(true) / window.bhSetGrid(false)
  (window as any).bhSetGrid = (on: boolean) => {
    if (!frame || !frame.contentWindow) return;
    const w = frame.contentWindow as any;
    if (typeof w.blackHoleSetGrid === "function") w.blackHoleSetGrid(on);
    else frame.contentWindow.postMessage({ type: "bh:setGrid", on }, location.origin);
  };
</script>

<style>
  .bh-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    /* Interactive: visitors drag the empty margins to orbit the black hole. */
    pointer-events: auto;
  }
</style>
