---
// ColliderField — abstract collision-reconstruction background (CV page). Each
// cycle: two beams come in from RANDOM points along the two side walls, meet at
// the centre, and BOOM — a spray of curved tracks reconstructs outward; it holds
// for 4 s, fades slowly over 6 s, then a fresh collision starts automatically.
// One of FIFTEEN real collider topologies per collision (see LABELS). Tracks curve
// in a magnetic field (low-pT → curls, high-pT → straight); jets are collimated
// bundles, leptons/photons clean straight tracks, plus MET vectors, calorimeter
// clusters and displaced vertices. Colourful pT scale by default; restrained
// ink+accent togglable. window.colliderRestart()/colliderSetColourful(bool) +
// a "collider:pattern" event drive the controls. Paused offscreen; reduced-motion
// shows one settled event with no motion.
---

<canvas class="collider-field" aria-hidden="true"></canvas>

<style>
  .collider-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>("canvas.collider-field");
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");
    const TAU = Math.PI * 2, PI = Math.PI;

    let ink = "#2b2b31", accent = "#7a5224", danger = "#a8442f";
    const readColours = () => {
      const cs = getComputedStyle(document.documentElement);
      ink = (cs.getPropertyValue("--text-primary") || ink).trim();
      accent = (cs.getPropertyValue("--accent") || accent).trim();
      danger = (cs.getPropertyValue("--danger") || danger).trim();
    };
    readColours();

    // ---- tunables ----------------------------------------------------------
    const T_APP = 1100;     // ms: beams travel in (medium speed)
    const BURST = 950;      // ms: the boom reconstructs outward
    const HOLD = 4000;      // ms: full event sits, no fading
    const FADE = 6000;      // ms: then it fades away slowly
    const QUICK_FADE = 450; // ms: the manual "restart" fade
    const ALPHA = 0.85;     // track opacity
    const VFX = 0.54, VFY = 0.47;   // collision point (fraction of W,H) — ~middle

    const HOLD_END = T_APP + BURST + HOLD;
    const SEQ = HOLD_END + FADE;          // one full cycle
    const FULL = T_APP + BURST + 100;     // a settled-full snapshot (for static redraws)

    const R = (a: number, b: number) => a + Math.random() * (b - a);
    const sgn = () => (Math.random() < 0.5 ? 1 : -1);
    const gaussish = () => (Math.random() + Math.random() + Math.random() - 1.5) / 1.5;

    let colourful = true;   // colour is the default; only explicit "off" turns it restrained
    try { const v = localStorage.getItem("collider-colour"); if (v !== null) colourful = v === "on"; } catch (e) {}

    type Trk = { pts: number[][]; w: number; pt: number; len: number };
    let W = 1, H = 1, dpr = 1, vx = 0, vy = 0, maxLen = 1;
    let tracks: Trk[] = [];
    let clusters: number[][] = [];
    let dvtx: number[] | null = null;
    let met: number | null = null;
    let beamSlope = 0;   // slope of the single straight beam-line that passes through the centre

    // ---- a single curved track, integrated step by step --------------------
    const makeTrack = (a0: number, pt: number, s: number, sx = vx, sy = vy): Trk => {
      const m = Math.min(W, H), ds = m * 0.018;
      const kappa = (1 - pt) * (1 - pt) * (R(8, 12) / m) * s;
      const maxSteps = Math.ceil(m * (0.45 + 1.7 * pt) / ds);
      const pts: number[][] = [[sx, sy]];
      let x = sx, y = sy, a = a0;
      for (let k = 0; k < maxSteps; k++) {
        a += kappa * ds; x += Math.cos(a) * ds; y += Math.sin(a) * ds;
        pts.push([x, y]);
        if (x < -0.1 * W || x > 1.1 * W || y < -0.1 * H || y > 1.1 * H) break;
      }
      let len = 0;
      for (let k = 1; k < pts.length; k++) len += Math.hypot(pts[k][0] - pts[k - 1][0], pts[k][1] - pts[k - 1][1]);
      return { pts, w: 0.7 + pt * 1.7, pt, len };
    };

    const add = (a0: number, pt: number, s: number, sx?: number, sy?: number) => {
      const t = makeTrack(a0, pt, s, sx, sy);
      if (t.len > maxLen) maxLen = t.len;
      tracks.push(t);
    };
    const jet = (axis: number, n: number, spread: number) => {
      for (let i = 0; i < n; i++) add(axis + gaussish() * spread, 0.45 + 0.55 * Math.pow(Math.random(), 0.6), sgn());
    };
    const soft = (n: number) => { for (let i = 0; i < n; i++) add(Math.random() * TAU, Math.pow(Math.random(), 3) * 0.4, sgn()); };
    const photon = (a0: number) => {
      add(a0, 1.0, 1);
      const r = Math.min(W, H) * 0.5;
      clusters.push([vx + Math.cos(a0) * r, vy + Math.sin(a0) * r]);
    };
    const clusterAt = (axis: number) => {
      const r = Math.min(W, H) * 0.5;
      clusters.push([vx + Math.cos(axis) * r, vy + Math.sin(axis) * r]);
    };

    // ---- the fifteen topologies -------------------------------------------
    const LABELS: Record<string, string> = {
      fireball: "fireball", heavyion: "heavy-ion", dijet: "dijet",
      threejet: "3-jet (Mercedes)", multijet: "multijet", fatjet: "boosted fat jet",
      resonance: "dijet resonance", fourlepton: "H→ZZ→4ℓ", dilepton: "Z→ℓℓ",
      wlnu: "W→ℓν", leptonjets: "lepton + jets", diphoton: "H→γγ",
      monojet: "mono-jet + MET", displaced: "displaced vertex", soft: "soft QCD",
    };
    const PATTERNS = Object.keys(LABELS);
    let lastPattern = "";
    const pickPattern = () => { let p = "fireball"; do { p = PATTERNS[Math.floor(Math.random() * PATTERNS.length)]; } while (p === lastPattern); return (lastPattern = p); };

    const buildPattern = (type: string) => {
      tracks = []; clusters = []; dvtx = null; met = null; maxLen = 1;
      const ax = () => Math.random() * TAU;
      if (type === "fireball") { for (let i = 0; i < 170; i++) add(ax(), Math.pow(Math.random(), 2), sgn()); }
      else if (type === "heavyion") { for (let i = 0; i < 290; i++) add(ax(), Math.pow(Math.random(), 2.4), sgn()); }
      else if (type === "dijet") { const a = ax(); jet(a, 46, 0.22); jet(a + PI, 46, 0.22); soft(26); }
      else if (type === "threejet") { const a = ax(); for (let j = 0; j < 3; j++) jet(a + j * TAU / 3, 34, 0.2); soft(24); }
      else if (type === "multijet") { const k = 4 + Math.floor(Math.random() * 2); for (let j = 0; j < k; j++) jet(ax(), 26, 0.2); soft(28); }
      else if (type === "fatjet") { jet(ax(), 92, 0.5); soft(20); }
      else if (type === "resonance") { const a = ax(); jet(a, 80, 0.42); jet(a + PI, 80, 0.42); clusterAt(a); clusterAt(a + PI); soft(16); }
      else if (type === "fourlepton") { const b = ax(); for (const a of [b, b + R(1.1, 1.7), b + PI + R(-0.3, 0.3), b + PI + R(1.1, 1.7)]) add(a, R(0.9, 1.0), sgn()); soft(8); }
      else if (type === "dilepton") { const a = ax(); add(a, R(0.9, 1), 1); add(a + PI + R(-0.15, 0.15), R(0.9, 1), -1); soft(14); }
      else if (type === "wlnu") { const a = ax(); add(a, R(0.9, 1), sgn()); met = a + PI + R(-0.4, 0.4); soft(16); }
      else if (type === "leptonjets") { const a = ax(); add(a, R(0.9, 1), sgn()); jet(a + R(1.5, 2.2), 28, 0.22); jet(a - R(1.5, 2.2), 28, 0.22); met = a + R(2.6, 3.7); soft(16); }
      else if (type === "diphoton") { const a = ax(); photon(a); photon(a + PI + R(-0.12, 0.12)); soft(20); }
      else if (type === "monojet") { const a = ax(); jet(a, 52, 0.22); met = a + PI + R(-0.2, 0.2); soft(16); }
      else if (type === "displaced") {
        for (let i = 0; i < 6; i++) add(ax(), Math.pow(Math.random(), 2) * 0.5, sgn());
        const da = ax(), dr = Math.min(W, H) * R(0.1, 0.2);
        dvtx = [vx + Math.cos(da) * dr, vy + Math.sin(da) * dr];
        for (let i = 0; i < 14; i++) add(da + R(-0.9, 0.9), Math.pow(Math.random(), 2), sgn(), dvtx[0], dvtx[1]);
      } else { for (let i = 0; i < 70; i++) add(ax(), Math.pow(Math.random(), 5) * 0.35, sgn()); }
    };

    const trackColour = (pt: number) =>
      colourful ? `hsl(${Math.round(220 - 210 * pt)}, 72%, 55%)` : (pt > 0.72 ? accent : ink);

    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    const drawBeams = (ap: number, alpha: number) => {
      const A = [W, vy + beamSlope * (W - vx)], B = [0, vy - beamSlope * vx];   // collinear through the centre
      ctx.globalAlpha = alpha; ctx.strokeStyle = accent; ctx.lineWidth = 2.2; ctx.lineCap = "round";
      for (const b of [A, B]) {
        const fx = b[0] + (vx - b[0]) * ap, fy = b[1] + (vy - b[1]) * ap;
        ctx.beginPath(); ctx.moveTo(b[0], b[1]); ctx.lineTo(fx, fy); ctx.stroke();
        ctx.fillStyle = accent; ctx.beginPath(); ctx.arc(fx, fy, 3, 0, TAU); ctx.fill();
      }
      ctx.globalAlpha = 1;
    };
    const drawCluster = (cx: number, cy: number, k: number, fade: number) => {
      ctx.fillStyle = colourful ? "hsl(58, 80%, 55%)" : ink;
      const n = Math.floor(16 * k), rad = 0.05 * Math.min(W, H);
      for (let i = 0; i < n; i++) {
        const ang = i * 2.39996, rr = (i / 16) * rad;
        ctx.globalAlpha = (0.2 + 0.3 * Math.random()) * fade;
        ctx.fillRect(cx + Math.cos(ang) * rr - 2, cy + Math.sin(ang) * rr - 2, 4, 4);
      }
      ctx.globalAlpha = 1;
    };
    const drawMET = (dir: number, reveal: number, fade: number) => {
      const m = Math.min(W, H), L = m * 0.5 * reveal;
      const ex = vx + Math.cos(dir) * L, ey = vy + Math.sin(dir) * L;
      ctx.save();
      ctx.globalAlpha = 0.65 * fade; ctx.strokeStyle = colourful ? danger : ink; ctx.lineWidth = 1.6;
      ctx.setLineDash([6, 5]); ctx.beginPath(); ctx.moveTo(vx, vy); ctx.lineTo(ex, ey); ctx.stroke();
      ctx.setLineDash([]);
      const ah = 11, aa = 0.42;
      ctx.beginPath();
      ctx.moveTo(ex, ey); ctx.lineTo(ex - ah * Math.cos(dir - aa), ey - ah * Math.sin(dir - aa));
      ctx.moveTo(ex, ey); ctx.lineTo(ex - ah * Math.cos(dir + aa), ey - ah * Math.sin(dir + aa));
      ctx.stroke();
      ctx.restore(); ctx.globalAlpha = 1;
    };

    const render = (elapsed: number, fade: number) => {
      ctx.clearRect(0, 0, W, H);
      ctx.lineCap = "round"; ctx.lineJoin = "round";
      if (elapsed < T_APP) { drawBeams(elapsed / T_APP, fade); return; }
      const bt = elapsed - T_APP;
      const front = easeOut(Math.min(bt / BURST, 1)) * maxLen;
      for (const t of tracks) {
        const upto = Math.max(1, Math.floor((t.pts.length - 1) * Math.min(1, front / t.len)));
        ctx.beginPath();
        ctx.moveTo(t.pts[0][0], t.pts[0][1]);
        for (let k = 1; k <= upto; k++) ctx.lineTo(t.pts[k][0], t.pts[k][1]);
        ctx.strokeStyle = trackColour(t.pt); ctx.lineWidth = t.w; ctx.globalAlpha = ALPHA * fade;
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
      const rev = Math.min(1, bt / BURST);
      for (const c of clusters) drawCluster(c[0], c[1], rev, fade);
      if (met !== null) drawMET(met, rev, fade);
      if (dvtx) {
        ctx.globalAlpha = 0.7 * fade; ctx.strokeStyle = colourful ? danger : accent; ctx.lineWidth = 1.4;
        ctx.beginPath(); ctx.arc(dvtx[0], dvtx[1], 5, 0, TAU); ctx.stroke(); ctx.globalAlpha = 1;
      }
      const ba = Math.max(0, 1 - bt / 300) * fade;
      if (ba > 0.01) drawBeams(1, ba);
      const flash = Math.max(0, 1 - bt / (BURST * 0.4));
      ctx.globalAlpha = (0.4 + 0.6 * flash) * fade; ctx.fillStyle = accent;
      ctx.beginPath(); ctx.arc(vx, vy, 2 + 14 * flash, 0, TAU); ctx.fill();
      ctx.globalAlpha = 1;
    };

    const phaseFade = (c: number) => c < HOLD_END ? 1 : Math.max(0, 1 - (c - HOLD_END) / FADE);

    // ---- lifecycle: auto-loop, paused offscreen ----------------------------
    let clock = 0, lastNow = 0, raf = 0, started = false, visible = false;
    let quickFading = false, qf = 0, frozenClock = 0;

    // a random line angle through the centre whose endpoints land ON the two side
    // walls (x=0 and x=W) and stay on-screen — the two beams are its two halves.
    const pickSlope = () => {
      const mg = 0.06 * H;
      const aL = (vy - (H - mg)) / vx, bL = (vy - mg) / vx;            // left endpoint on-screen
      const aR = (mg - vy) / (W - vx), bR = (H - mg - vy) / (W - vx);  // right endpoint on-screen
      const lo = Math.max(aL, aR), hi = Math.min(bL, bR);
      return lo < hi ? R(lo, hi) : 0;
    };

    const initSequence = () => {
      const key = pickPattern();
      buildPattern(key);
      beamSlope = pickSlope();   // a new straight line through the centre, random angle
      try {
        (window as any).colliderPattern = LABELS[key];
        window.dispatchEvent(new CustomEvent("collider:pattern", { detail: LABELS[key] }));
      } catch (e) {}
    };

    const redraw = () => { if (!started) render(FULL, 1); else render(clock, phaseFade(clock)); };

    const frame = (now: number) => {
      raf = requestAnimationFrame(frame);
      if (!visible) { lastNow = now; return; }   // freeze offscreen
      if (now - lastNow < 32) return;            // ~30fps + dt gate
      const dt = Math.min(now - lastNow, 50); lastNow = now;
      if (quickFading) {
        qf += dt;
        render(frozenClock, Math.max(0, 1 - qf / QUICK_FADE));
        if (qf >= QUICK_FADE) { quickFading = false; initSequence(); clock = 0; }
        return;
      }
      clock += dt;
      if (clock >= SEQ) { clock -= SEQ; initSequence(); }   // auto: next collision
      render(clock, phaseFade(clock));
    };

    const start = () => { if (started) return; started = true; initSequence(); clock = 0; lastNow = performance.now(); raf = requestAnimationFrame(frame); };
    const restart = () => {
      if (!started) { start(); return; }
      if (quickFading) return;
      frozenClock = clock; qf = 0; quickFading = true;
    };

    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth; H = canvas.clientHeight;
      canvas.width = Math.max(1, Math.round(W * dpr)); canvas.height = Math.max(1, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      vx = W * VFX; vy = H * VFY;
      beamSlope = pickSlope();
      buildPattern(lastPattern || pickPattern());
      redraw();
    };
    resize();
    window.addEventListener("resize", resize);

    new MutationObserver(() => { readColours(); redraw(); })
      .observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });

    (window as any).colliderRestart = restart;
    (window as any).colliderSetColourful = (on: boolean) => { colourful = !!on; redraw(); };

    if (reduce.matches) {
      initSequence(); render(FULL, 1);            // one settled event, no motion
    } else {
      const io = new IntersectionObserver((es) => { visible = es[0].isIntersecting; if (visible) start(); });
      io.observe(canvas);
    }
  }
</script>
