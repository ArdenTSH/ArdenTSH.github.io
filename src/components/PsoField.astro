---
// PsoField — ambient background for the computational/materials page: live
// particle-swarm optimisation drawn as a notebook contour plot scrolling LEFT.
// Real PSO: each particle is pulled by its OWN best (cognitive) AND the swarm's
// best-found point (social / gbest — DISCOVERED, not a scripted target). The
// landscape genuinely has a deep global minimum (a well carved into the terrain);
// the swarm explores first, then the social pull ramps in and it converges onto
// the lowest point it has actually found. Wells alternate bottom/top; the whole
// landscape is tilted slightly downhill to the LEFT (right edge highest), so the
// swarms head downhill as they cross. Crosses + velocity arrows. A bottom-right
// control (PsoControls) toggles a depth colour map (light-green shallow → dark-blue
// deep), OFF by default. Theme-adaptive; paused offscreen; reduced-motion renders a
// single settled frame.
---

<canvas class="pso-field" aria-hidden="true"></canvas>

<style>
  .pso-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }
</style>

<script>
  const canvas = document.querySelector<HTMLCanvasElement>("canvas.pso-field");
  const ctx = canvas?.getContext("2d");
  if (canvas && ctx) {
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)");

    let ink = "#2b2b31", accent = "#7a5224", paper = "#efe5cf";
    const readColours = () => {
      const cs = getComputedStyle(document.documentElement);
      ink = (cs.getPropertyValue("--text-primary") || ink).trim();
      accent = (cs.getPropertyValue("--accent") || accent).trim();
      paper = (cs.getPropertyValue("--bg") || paper).trim();
    };
    readColours();
    const themeObserver = new MutationObserver(readColours);
    themeObserver.observe(document.documentElement, {
      attributes: true, attributeFilter: ["data-theme"],
    });

    // depth colour map — OFF by default (the page stays ink-on-paper). PsoControls flips this through
    // window.psoSetColour; we also read the saved choice up front so the first paint already matches.
    let colourOn = false;
    try { colourOn = localStorage.getItem("pso-colour") === "on"; } catch (e) {}

    let W = 1, H = 1, dpr = 1;
    const resize = () => {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth; H = canvas.clientHeight;
      canvas.width = Math.max(1, Math.round(W * dpr));
      canvas.height = Math.max(1, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    };
    resize();
    window.addEventListener("resize", resize);

    let seed = 20260615.5;
    const rnd = () => { seed = (seed * 9301 + 49297) % 233280; return seed / 233280; };

    const SCALE = 62;
    let scroll = 0;
    const DRIFT = 0.014;             // constant leftward drift (terrain + particles ride it)
    const worldW = () => W / SCALE;
    const worldH = () => H / SCALE;

    // ── HORIZONTAL CONVENTION ──────────────────────────────────────────────
    // Every horizontal position below is a fraction p ACROSS THE SCREEN FROM THE
    // RIGHT EDGE: p=0 is the right border, p increases leftward, p=1 is the left
    // border. p<0 is off-screen right, p>1 is off-screen left. To turn a p into a
    // world-x offset from `scroll`: offset = (1 − p)·worldW(); screen-x = (1 − p)·W.
    // This is exactly the `progress` variable computed in step(). (Vertical stays
    // top-referenced: 0 = top, 1 = bottom — a separate axis.)
    const N_SWARMS = 5, PER = 15;    // a few extra swarm slots so one is idle when a well reaches its trigger
    const SPAWN_P = -0.025;          // p of the entry-band CENTRE: 2.5% past the right edge (p<0 = off-screen right)
    const SPAWN_BAND = 0.05;         // p-width of the entry band (±0.025) → band spans p ∈ [−0.05, 0]
    const EXIT_P = 1.05;             // p where a batch recycles (goes idle): 5% past the LEFT edge (p>1 = off-screen left)
    const EXPLOIT_AT = 0.6;          // converged by p≈0.6 (60% across from the right edge)
    const W_MIN = 0.2, W_MAX = 0.95;  // inertia: linearly decreasing across the crossing (high -> low). >1 would need a speed cap to stay stable; <1 is stable on its own
    const C1 = 0.12;                 // cognitive: pull to the particle's OWN best (self-tether)
    const C2 = 0.03;                 // social: pull to gbest (core PSO, ON throughout). gentle while searching...
    const C2_HIGH = 0.17, C2_RAMP_AT = 0.30, C2_RAMP_END = 0.56; // ...then ramps LINEARLY 0.04 -> 0.28 between p=0.26 and p=0.46 (across from the right), to gather harder once the well is found
    const THERMAL = 0.012, TH_DAMP = 0.6; // wobble; damps as the cluster settles (no speed cap — the decreasing w<1 keeps it stable)
    // entry dash: a gentle leftward boost held at BOOST for the first 3.5% of the crossing, then
    // easing LINEARLY to BOOST_TAIL by 13%, held at BOOST_TAIL until 37% across (BOOST_TAIL_END),
    // then easing LINEARLY down to 0 by 50% (BOOST_OFF) — a sustained gentle push, no hard shot. Its
    // vertical component fans the swarm OUTWARD (top up / bottom down) from 7%->25% across, then pulls
    // it INWARD (gather toward mid-height) 25%->40%, so it visibly spreads to search then draws back
    // in. DASH_OUT scales that splay.
    const BOOST = 0.09, BOOST_TAIL = 0.05, BOOST_TAIL_END = 0.27, BOOST_OFF = 0.4, DASH_HOLD = 0.035, DASH_END = 0.13, DASH_TAIL = 0.40, DASH_OUT = 0.4;
    const DASH_OUT_AT = 0.07, DASH_IN_AT = 0.25;   // vertical splay: OUTward 7%->25%, then INward 25%->40%
    // the global minima: a PERIODIC field of basins that ALWAYS exist in the world and scroll in from
    // the right (never spawned mid-screen). Wells sit at x = k·WELL_SPACING·worldW(), y alternating by parity,
    // carved in WARPED space (organic, never circular). A swarm spawns each time a well crosses
    // WELL_TRIGGER across, then DISCOVERS it via gbest as it journeys in — no seeding, no steering.
    const WELL_DEPTH_A = 2, WELL_SIG_A = 4;        // each well = TWO basins, same centre: a broad one (depth 4, σ 4)...
    const WELL_DEPTH_B = 2, WELL_SIG_B = 0.5;      // ...plus a narrow one (depth 2, σ 1.5) for a sharper bottom
    const WELL_SPACING = 0.4, WELL_TRIGGER = 0.27; // wells 0.4 (40%) of the SCREEN WIDTH apart (·worldW() → world units); a swarm spawns when a well reaches p=0.29 (29% across from the RIGHT edge)
    // widen ONLY the first->second well gap (the pair you see at page load); every later gap
    // stays at WELL_SPACING. firstWellK = the well the first swarm dives into at load; every
    // well AFTER it is pushed right by FIRST_GAP_EXTRA, so just that one seam grows.
    const firstWellK = 0;            // well 0 is the load-time well (sits at p=WELL_PHASE), the FIRST_GAP_EXTRA seam AND the first swarm's target. nextWellK starts here, so well 0 is the first to cross WELL_TRIGGER and spawn a swarm (~1s after load — the WELL_PHASE→WELL_TRIGGER gap is only 0.02 of screen width).
    const FIRST_GAP_EXTRA = 0.02;      // fraction of SCREEN WIDTH added to the first->second gap only (≈ the old 0.5 world units; 0 = uniform). tune to taste
    const WELL_PHASE = 0.25;         // p of well k=0 at scroll=0: it sits at p=0.27 (27% across from the RIGHT edge); later wells start off-screen right (lower p) and stream in
    const wellX = (k: number) => ((1 - WELL_PHASE) + k * WELL_SPACING + (k > firstWellK ? FIRST_GAP_EXTRA : 0)) * worldW(); // all terms are screen-width fractions → ·worldW() once = world x

    type Swarm = {
      wx: Float32Array; wy: Float32Array; vx: Float32Array; vy: Float32Array;
      pbx: Float32Array; pby: Float32Array; pbo: Float32Array;
      cx: number; gbx: number; gby: number; gbo: number;   // centre + the swarm's discovered global best
      active: boolean;                                       // idle swarm slots (awaiting a well trigger) are skipped
    };
    const makeSwarm = (): Swarm => ({
      wx: new Float32Array(PER), wy: new Float32Array(PER),
      vx: new Float32Array(PER), vy: new Float32Array(PER),
      pbx: new Float32Array(PER), pby: new Float32Array(PER), pbo: new Float32Array(PER),
      cx: -1e9, gbx: 0, gby: 0, gbo: 1e9, active: false,
    });
    const swarms: Swarm[] = [];

    // domain warp -> organic terrain (and, reused below, warped wells so they
    // aren't perfect circles).
    const warpX = (wx: number, wy: number) => wx + 0.8 * Math.sin(wy * 0.7 + 1.3) + 0.4 * Math.cos(wy * 1.9 - 0.5);
    const warpY = (wx: number, wy: number) => wy + 0.8 * Math.cos(wx * 0.6 - 0.8) + 0.4 * Math.sin(wx * 1.8 + 0.9);
    const TERRAIN_FLAT = 0.85;        // scales the whole terrain proportionally: flatter relief, identical contour shape (1.0 = original)
    const terrainAt = (ax: number, ay: number) => {
      let z = 0;
      z -= 1.0 * Math.cos(ax * 1.0) * Math.cos(ay * 1.0);
      z -= 0.55 * Math.cos(ax * 1.7 + 0.6) * Math.cos(ay * 1.5 + 0.4);
      z -= 0.35 * Math.cos(ax * 0.6 - 0.3) * Math.cos(ay * 0.8 + 1.1);
      z -= 0.28 * Math.sin(ax * 2.3 + ay * 1.3 + 0.7);
      z -= 0.2 * Math.cos(ax * 3.1 - 0.2) * Math.cos(ay * 2.6 + 0.9);
      return z * TERRAIN_FLAT;          // uniform scale -> slightly flatter, contour pattern unchanged
    };
    // persistent periodic wells: rebuilt each frame from world position (deterministic), so the global
    // minima ALWAYS exist and scroll in from the right — never spawned mid-screen.
    type Well = { x: number; y: number; wax: number; way: number };
    let wells: Well[] = [];
    const rebuildWells = () => {
      wells = [];
      const wH = worldH(), m = 3 * WELL_SIG_A, sp = WELL_SPACING * worldW();   // m: include wells whose (broad) tails still reach the edges. sp: well spacing in world units
      const k0 = Math.floor((scroll - m) / sp), k1 = Math.ceil((scroll + worldW() + m) / sp);
      for (let k = k0; k <= k1; k++) {
        const x = wellX(k), y = (((k % 2) + 2) % 2 === 0 ? 0.27 : 0.73) * wH;
        wells.push({ x, y, wax: warpX(x, y), way: warpY(x, y) });
      }
    };
    // a SLIGHT global tilt of the whole landscape: high at the RIGHT edge, low at the LEFT, so the
    // surface slopes downhill leftward — the direction the world scrolls and the swarms travel, so a
    // particle is always heading downhill as it crosses. SCREEN-relative (a function of on-screen x via
    // (wx − scroll)/worldW, NOT absolute world x), so the mean tilt stays ~0 and it never drifts out of
    // the contour range as the world scrolls. computeGrid adds the identical ramp per screen column.
    const TILT = 1.5;   // z drop from the right edge to the left edge (≈5 contour levels of slope); 0 = flat
    const tiltAt = (wx: number) => TILT * ((wx - scroll) / worldW() - 0.5);   // +½·TILT at right edge, −½·TILT at left
    // the LANDSCAPE the particles search and the contours draw: rolling terrain PLUS the periodic wells
    // (subtracted in WARPED space so level sets stay organic) PLUS the slight leftward downhill tilt.
    const landscapeF = (wx: number, wy: number) => {
      const ax = warpX(wx, wy), ay = warpY(wx, wy);
      let z = terrainAt(ax, ay);
      for (const w of wells) {
        const dx = ax - w.wax, dy = ay - w.way, d2 = dx * dx + dy * dy;
        z -= WELL_DEPTH_A * Math.exp(-d2 / (2 * WELL_SIG_A * WELL_SIG_A));   // broad basin
        z -= WELL_DEPTH_B * Math.exp(-d2 / (2 * WELL_SIG_B * WELL_SIG_B));   // + narrow basin (same centre)
      }
      return z + tiltAt(wx);
    };
    const FMIN = -6, FMAX = 2.4;      // contour level range; FMIN rings most of the deep two-basin wells (bottom ~-7.5)

    const spawnSwarm = (s: Swarm, targetX: number) => {
      const wH = worldH(), wW = worldW();
      s.cx = targetX; s.gbo = 1e9; s.active = true;
      for (let k = 0; k < PER; k++) {
        s.wx[k] = targetX + (rnd() - 0.5) * SPAWN_BAND * wW; // enter as a loose band ~5% off the right edge
        s.wy[k] = (0.12 + 0.76 * rnd()) * wH;              // spread across the height
        s.vx[k] = -(0.05 + 0.03 * rnd());                  // leftward boost (carries them in)
        s.vy[k] = (rnd() - 0.5) * 0.03;
        s.pbx[k] = s.wx[k]; s.pby[k] = s.wy[k];
        s.pbo[k] = landscapeF(s.wx[k], s.wy[k]);
        if (s.pbo[k] < s.gbo) { s.gbx = s.pbx[k]; s.gby = s.pby[k]; s.gbo = s.pbo[k]; }  // init gbest
      }
    };
    // the wells exist from frame 0 (a scrolling field); swarms stream in as wells reach the trigger.
    for (let i = 0; i < N_SWARMS; i++) swarms.push(makeSwarm());
    rebuildWells();
    let nextWellK = firstWellK; // next well index to trigger a swarm (= firstWellK = 0 => well 0, at p=0.33, crosses the p=0.36 trigger ~1.7s after load)

    // ---- entry-boost DIRECTION (per particle) -------------------------------
    // The boost SIZE comes from the schedule in step(); these only set its DIRECTION
    // (same magnitude either way — "change the direction, not the velocity"). Two
    // interchangeable versions; flip TWO_POINT_BOOST to switch. Both kept so the old
    // splay stays tweakable.
    const TWO_POINT_BOOST = true;
    const SPLIT_P = 0.65;            // vertical aim-line at p=0.65 (65% across from the RIGHT edge)
    // aim the boost at one of two points: where the SPLIT_P line meets the top /
    // bottom boundary. Top-half particles aim at the top point, bottom-half at the bottom
    // one. An edge (near top/bottom) particle's aim is almost horizontal (small outward
    // angle); a mid-height particle's is steep (big angle) — so the swarm is thrown into a
    // top batch + a bottom batch, which reconverge once the boost fades and gbest gathers
    // them back to the well.
    const entryBoostTwoPoint = (wx: number, wy: number, boost: number, wH: number): [number, number] => {
      const tx = scroll + (1 - SPLIT_P) * worldW();  // target column (world x), pinned at p=SPLIT_P across from the RIGHT
      const ty = wy < 0.5 * wH ? 0 : wH;             // top half -> top boundary, bottom half -> bottom boundary
      const dx = tx - wx, dy = ty - wy, len = Math.hypot(dx, dy) || 1e-6;
      return [boost * dx / len, boost * dy / len];   // unit aim × |boost| (magnitude unchanged)
    };
    // OLD — leftward push + a vertical splay that fans OUT then IN around mid-height,
    // scaled by each particle's distance from the middle (kept for reverting / tweaking).
    const entryBoostSplay = (wy: number, boost: number, vdir: number, cy: number, wH: number): [number, number] =>
      [-boost, vdir * DASH_OUT * boost * (wy - cy) / (0.5 * wH)];

    // chaotic inertia (Feng 2007): a logistic map iterated each frame supplies the chaotic term z.
    let chaosZ = 0.37;
    const step = () => {
      scroll += DRIFT;
      chaosZ = 4 * chaosZ * (1 - chaosZ);   // logistic map -> sustained stochastic kicks throughout the run
      rebuildWells();                        // the periodic well field scrolls in with the world
      // a swarm spawns each time a well crosses WELL_TRIGGER across, so it journeys in to that well
      while (scroll >= wellX(nextWellK) - (1 - WELL_TRIGGER) * worldW()) {
        const idle = swarms.find((s) => !s.active);
        if (idle) spawnSwarm(idle, scroll + (1 - SPAWN_P) * worldW());
        nextWellK++;
      }
      const wH = worldH();
      for (const s of swarms) {
        if (!s.active) continue;
        // the centre TRACKS the particles (which fly in on their boost, then search the terrain).
        let sumx = 0; for (let k = 0; k < PER; k++) sumx += s.wx[k];
        s.cx += (sumx / PER - s.cx) * 0.12;
        const cScreen = (s.cx - scroll) * SCALE;
        const progress = Math.min(Math.max((W - cScreen) / W, 0), 1);
        const exploit = Math.min(progress / EXPLOIT_AT, 1);
        const w = (W_MAX - W_MIN) * (1 - progress) + W_MIN * chaosZ; // chaotic inertia (Feng 2007): linear envelope + W_MIN·z logistic-map kick
        const cCog = C1 * (1.0 - 0.4 * exploit); // self-tether, eases as it converges
        // social pull toward the swarm's DISCOVERED best (gbest): ON the whole time (standard PSO).
        // Gentle (C2) while exploring, then ramps up to C2_HIGH between 32%->38% across so it gathers
        // harder into the well once found — no scripted target.
        const cSoc = progress < C2_RAMP_AT ? C2
                   : progress < C2_RAMP_END ? C2 + (C2_HIGH - C2) * (progress - C2_RAMP_AT) / (C2_RAMP_END - C2_RAMP_AT)
                   : C2_HIGH;
        const thermal = THERMAL * (1 - TH_DAMP * exploit); // wobble damps as the cluster settles
        // entry dash, by the swarm's progress across the screen: BOOST for the first 3.5%, ease to
        // BOOST_TAIL by 13%, hold to 37% (BOOST_TAIL_END), then ease LINEARLY down to 0 by 50% (BOOST_OFF).
        let boost = 0;
        if (progress < DASH_HOLD) boost = BOOST;
        else if (progress < DASH_END) boost = BOOST + (BOOST_TAIL - BOOST) * (progress - DASH_HOLD) / (DASH_END - DASH_HOLD);
        else if (progress < BOOST_TAIL_END) boost = BOOST_TAIL;
        else if (progress < BOOST_OFF) boost = BOOST_TAIL * (1 - (progress - BOOST_TAIL_END) / (BOOST_OFF - BOOST_TAIL_END));
        const cy = 0.5 * wH;                             // mid-height: the swarm fans out / gathers in around this
        // vertical splay direction: +1 outward (fan apart) 7%->25%, −1 inward (gather) 25%->40%, else 0
        const vdir = (progress >= DASH_OUT_AT && progress < DASH_IN_AT) ? 1
                   : (progress >= DASH_IN_AT && progress < DASH_TAIL) ? -1 : 0;
        for (let k = 0; k < PER; k++) {
          const r1x = rnd(), r1y = rnd(), r2x = rnd(), r2y = rnd();  // independent randoms per dimension
          // entry boost — NEW two-point aim (default) or the OLD outward/inward splay; same magnitude.
          const [bx, by] = TWO_POINT_BOOST
            ? entryBoostTwoPoint(s.wx[k], s.wy[k], boost, wH)
            : entryBoostSplay(s.wy[k], boost, vdir, cy, wH);
          s.vx[k] = w * s.vx[k] + cCog * r1x * (s.pbx[k] - s.wx[k]) + cSoc * r2x * (s.gbx - s.wx[k]) + bx + (rnd() - 0.5) * thermal;
          s.vy[k] = w * s.vy[k] + cCog * r1y * (s.pby[k] - s.wy[k]) + cSoc * r2y * (s.gby - s.wy[k]) + by + (rnd() - 0.5) * thermal;
          // no speed cap — inertia (w < 1, linearly decreasing) keeps the dynamics stable on its own.
          s.wx[k] += s.vx[k]; s.wy[k] += s.vy[k];
          if (s.wy[k] < 0) { s.wy[k] = -s.wy[k]; s.vy[k] = -s.vy[k]; }
          else if (s.wy[k] > wH) { s.wy[k] = 2 * wH - s.wy[k]; s.vy[k] = -s.vy[k]; }
          const o = landscapeF(s.wx[k], s.wy[k]);
          if (o < s.pbo[k]) {                              // update personal best, then global best
            s.pbx[k] = s.wx[k]; s.pby[k] = s.wy[k]; s.pbo[k] = o;
            if (o < s.gbo) { s.gbx = s.wx[k]; s.gby = s.wy[k]; s.gbo = o; }
          }
        }
        if (cScreen < (1 - EXIT_P) * W) s.active = false;  // centroid p > EXIT_P (past the left edge) -> idle, await a well trigger
      }
    };

    // ---- contour lines via marching squares ---------------------------------
    const GX = 108, GY = 72, LEVELS = 30;
    const grid = new Float32Array((GX + 1) * (GY + 1));
    const lerp = (la: number, lb: number, L: number) => (L - la) / (lb - la || 1e-6);

    // ---- depth colour map (toggle) ------------------------------------------
    // When colour mode is on, paint the landscape as a filled heatmap UNDER the contour lines: light
    // green where it's high/shallow → dark blue where it's deep. Built at grid resolution into a tiny
    // offscreen canvas, then drawn scaled-up WITH smoothing for a clean gradient (cheap — ~8k texels a
    // frame). Default OFF, so by default none of this runs and the ink-on-paper look is unchanged.
    const COL_LO = -5.0, COL_HI = 1.6;   // z mapped to the ramp ends (below → deepest blue, above → lightest green)
    const RAMP: [number, number, number, number][] = [
      [0.00, 12, 26, 60],     // deepest — dark blue
      [0.34, 26, 72, 112],    // blue
      [0.62, 40, 126, 132],   // teal
      [1.00, 198, 226, 150],  // shallowest / highest — light green
    ];
    // writes z's ramp colour straight into the ImageData buffer at byte offset `off` — no per-node array
    // alloc (this runs ~8k×/frame when colour is on). d is Uint8ClampedArray, so the floats auto-clamp.
    const rampColour = (z: number, d: Uint8ClampedArray, off: number) => {
      let t = (z - COL_LO) / (COL_HI - COL_LO);
      t = t < 0 ? 0 : t > 1 ? 1 : t;
      for (let s = 1; s < RAMP.length; s++) {
        if (t <= RAMP[s][0]) {
          const a = RAMP[s - 1], b = RAMP[s], f = (t - a[0]) / (b[0] - a[0] || 1e-6);
          d[off] = a[1] + (b[1] - a[1]) * f; d[off + 1] = a[2] + (b[2] - a[2]) * f; d[off + 2] = a[3] + (b[3] - a[3]) * f;
          return;
        }
      }
      const e = RAMP[RAMP.length - 1];
      d[off] = e[1]; d[off + 1] = e[2]; d[off + 2] = e[3];
    };
    const fillCanvas = document.createElement("canvas");
    fillCanvas.width = GX + 1; fillCanvas.height = GY + 1;
    const fillCtx = fillCanvas.getContext("2d");
    const fillImg = fillCtx?.createImageData(GX + 1, GY + 1) ?? null;
    // grid[n] and ImageData texel n share the SAME row-major layout (row j, col i → n = j·(GX+1)+i),
    // so a single linear pass maps each landscape node to its pixel.
    const drawFill = () => {
      if (!fillCtx || !fillImg) return;
      const d = fillImg.data, total = (GX + 1) * (GY + 1);
      for (let n = 0; n < total; n++) {
        const o = n * 4;
        rampColour(grid[n], d, o);
        d[o + 3] = 255;
      }
      fillCtx.putImageData(fillImg, 0, 0);
      const prev = ctx.imageSmoothingEnabled;
      ctx.imageSmoothingEnabled = true;
      // sample from texel CENTRES (source inset ½ texel): maps grid node i to dest x = i·(W/GX) — exactly
      // where drawLines draws node i — so the colour fill registers with the contour lines (no ½-cell drift).
      ctx.drawImage(fillCanvas, 0.5, 0.5, GX, GY, 0, 0, W, H);
      ctx.imageSmoothingEnabled = prev;
    };
    // terrain cache: terrainAt(warp(...)) is rigid in world space (the scene only scrolls
    // left), so each world-column's (terrain, warped-x, warped-y) is evaluated ONCE and
    // reused. Per frame we interpolate between columns and add the moving wells (just exp,
    // no trig) — cutting ~110k trig/frame. Cleared when the cell geometry changes (resize).
    const colCache = new Map<number, Float32Array>();
    let cacheW = 0, cacheH = 0;
    const buildColumn = (c: number, cwW: number, cwH: number) => {
      const arr = new Float32Array((GY + 1) * 3), wx = c * cwW;
      for (let j = 0; j <= GY; j++) {
        const wy = j * cwH, ax = warpX(wx, wy), ay = warpY(wx, wy);
        arr[j * 3] = terrainAt(ax, ay); arr[j * 3 + 1] = ax; arr[j * 3 + 2] = ay;
      }
      colCache.set(c, arr);
      return arr;
    };
    const computeGrid = () => {
      const cwW = worldW() / GX, cwH = worldH() / GY;
      if (cwW !== cacheW || cwH !== cacheH) { colCache.clear(); cacheW = cwW; cacheH = cwH; }
      const c0 = Math.floor(scroll / cwW), frac = scroll / cwW - c0, g0 = 1 - frac;
      if (colCache.size > GX + 40) for (const k of colCache.keys()) if (k < c0 - 2) colCache.delete(k);
      const col = (c: number) => colCache.get(c) || buildColumn(c, cwW, cwH);
      for (let i = 0; i <= GX; i++) {
        const ca = col(c0 + i), cb = col(c0 + i + 1);
        const tilt = TILT * (i / GX - 0.5);   // same screen-relative ramp as landscapeF: right edge high, left edge low
        for (let j = 0; j <= GY; j++) {
          const ax = ca[j * 3 + 1] * g0 + cb[j * 3 + 1] * frac;
          const ay = ca[j * 3 + 2] * g0 + cb[j * 3 + 2] * frac;
          let z = ca[j * 3] * g0 + cb[j * 3] * frac;
          for (const w of wells) {
            const dx = ax - w.wax, dy = ay - w.way, d2 = dx * dx + dy * dy;
            z -= WELL_DEPTH_A * Math.exp(-d2 / (2 * WELL_SIG_A * WELL_SIG_A));   // broad basin
            z -= WELL_DEPTH_B * Math.exp(-d2 / (2 * WELL_SIG_B * WELL_SIG_B));   // + narrow basin (same centre)
          }
          grid[j * (GX + 1) + i] = z + tilt;
        }
      }
    };
    const drawLines = () => {
      const cw = W / GX, ch = H / GY;
      // over the colour fill, dark ink lines vanish into the deep-blue wells — switch to faint white
      // isobath-style lines that read on both the green shallows and the blue depths.
      ctx.lineWidth = 1; ctx.lineJoin = "round"; ctx.lineCap = "round";
      ctx.strokeStyle = colourOn ? "#ffffff" : ink;
      for (let l = 1; l <= LEVELS; l++) {
        const L = FMIN + ((FMAX - FMIN) * l) / (LEVELS + 1);
        ctx.beginPath();
        for (let j = 0; j < GY; j++) {
          for (let i = 0; i < GX; i++) {
            const tl = grid[j * (GX + 1) + i];
            const tr = grid[j * (GX + 1) + i + 1];
            const br = grid[(j + 1) * (GX + 1) + i + 1];
            const bl = grid[(j + 1) * (GX + 1) + i];
            let c = 0;
            if (tl > L) c |= 8; if (tr > L) c |= 4; if (br > L) c |= 2; if (bl > L) c |= 1;
            if (c === 0 || c === 15) continue;
            const x0 = i * cw, y0 = j * ch;
            const pT = [x0 + cw * lerp(tl, tr, L), y0];
            const pR = [x0 + cw, y0 + ch * lerp(tr, br, L)];
            const pB = [x0 + cw * lerp(bl, br, L), y0 + ch];
            const pLft = [x0, y0 + ch * lerp(tl, bl, L)];
            const seg = (a: number[], b: number[]) => { ctx.moveTo(a[0], a[1]); ctx.lineTo(b[0], b[1]); };
            switch (c) {
              case 1: case 14: seg(pLft, pB); break;
              case 2: case 13: seg(pB, pR); break;
              case 3: case 12: seg(pLft, pR); break;
              case 4: case 11: seg(pT, pR); break;
              case 6: case 9: seg(pT, pB); break;
              case 7: case 8: seg(pLft, pT); break;
              case 5: seg(pLft, pT); seg(pB, pR); break;
              case 10: seg(pT, pR); seg(pLft, pB); break;
            }
          }
        }
        ctx.globalAlpha = colourOn ? 0.16 + 0.05 * (l / LEVELS) : 0.14 + 0.04 * (l / LEVELS);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    };

    const DEBUG_WELLS = false;  // DIAGNOSTIC: green dot at each well centre (well-tuning aid). Flip to true to show; code kept below.
    const draw = () => {
      ctx.clearRect(0, 0, W, H);
      computeGrid();
      if (colourOn) drawFill();
      drawLines();
      for (const s of swarms) {
        if (!s.active) continue;
        for (let k = 0; k < PER; k++) {
          const cx = (s.wx[k] - scroll) * SCALE, cy = s.wy[k] * SCALE;
          if (cx < -16 || cx > W + 16) continue;
          let ex = cx + s.vx[k] * SCALE * 5, ey = cy + s.vy[k] * SCALE * 5;
          let vlen = Math.hypot(ex - cx, ey - cy);
          if (vlen > 22) { const f = 22 / vlen; ex = cx + (ex - cx) * f; ey = cy + (ey - cy) * f; vlen = 22; }
          // in colour mode a theme `accent` arrow (graphite in the notebook theme) would vanish into the
          // dark-blue deep regions — use a light stroke there, matching the white isobath lines.
          ctx.globalAlpha = colourOn ? 0.7 : 0.6; ctx.strokeStyle = colourOn ? "#dfe7ef" : accent; ctx.lineWidth = 1.2; ctx.lineCap = "round";
          ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(ex, ey);
          if (vlen > 5) {
            const ang = Math.atan2(ey - cy, ex - cx); const ah = 3.8;
            ctx.moveTo(ex, ey); ctx.lineTo(ex - ah * Math.cos(ang - 0.5), ey - ah * Math.sin(ang - 0.5));
            ctx.moveTo(ex, ey); ctx.lineTo(ex - ah * Math.cos(ang + 0.5), ey - ah * Math.sin(ang + 0.5));
          }
          ctx.stroke();
          ctx.globalAlpha = 0.92; ctx.fillStyle = paper;
          ctx.beginPath(); ctx.arc(cx, cy, 4.2, 0, Math.PI * 2); ctx.fill();
          const r = 3;
          ctx.globalAlpha = 1; ctx.strokeStyle = ink; ctx.lineWidth = 1.5; ctx.lineCap = "round";
          ctx.beginPath();
          ctx.moveTo(cx - r, cy - r); ctx.lineTo(cx + r, cy + r);
          ctx.moveTo(cx - r, cy + r); ctx.lineTo(cx + r, cy - r);
          ctx.stroke();
        }
      }
      // ---- DIAGNOSTIC: green dot at each persistent well centre (the global minima). Visual only —
      // does NOT touch landscapeF or the dynamics. Toggle with DEBUG_WELLS above.
      if (DEBUG_WELLS) {
        for (const w of wells) {
          const mx = (w.x - scroll) * SCALE, my = w.y * SCALE;
          if (mx < -20 || mx > W + 20) continue;
          ctx.globalAlpha = 0.95; ctx.fillStyle = "#2ee65c";                  // green dot at each persistent well centre
          ctx.beginPath(); ctx.arc(mx, my, 5, 0, Math.PI * 2); ctx.fill();
        }
      }
      ctx.globalAlpha = 1;
    };

    let last = 0, raf = 0, visible = true;
    const frame = (now: number) => {
      raf = requestAnimationFrame(frame);
      if (!visible) return;
      if (now - last < 33) return;
      last = now;
      step();
      draw();
    };
    let io: IntersectionObserver | null = null;
    if (reduce.matches) {
      for (let n = 0; n < 400; n++) step();
      draw();
    } else {
      raf = requestAnimationFrame(frame);
      io = new IntersectionObserver((es) => { visible = es[0].isIntersecting; });
      io.observe(canvas);
    }
    // PsoControls toggles the depth colour map through this hook. Under reduced motion there's no
    // animation loop, so redraw the single static frame immediately when it flips.
    (window as any).psoSetColour = (on: boolean) => {
      colourOn = !!on;
      if (reduce.matches) draw();
    };
    // tidy up under Astro client navigation / view transitions — don't leak a RAF loop
    // or observers driving a now-detached canvas.
    const cleanup = () => {
      cancelAnimationFrame(raf);
      io?.disconnect();
      themeObserver.disconnect();
      window.removeEventListener("resize", resize);
      delete (window as any).psoSetColour;
      document.removeEventListener("astro:before-swap", cleanup);
    };
    document.addEventListener("astro:before-swap", cleanup);
  }
</script>
