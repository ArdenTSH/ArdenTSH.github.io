---
// ColliderControls — bottom-right controls for the CV page's collision background.
// "colour" cycles three modes — colourful (full pT rainbow) → quiet (colour by
// object type) → muted (monochrome ink) — persisted in localStorage; the readout
// shows which of the 15 topologies is on screen; "restart" fades the current
// collision out and fires a fresh one. Driven by the window hooks ColliderField
// exposes (colliderSetMode / colliderRestart / "collider:pattern").
---

<div class="collider-controls">
  <button type="button" class="cc-btn" data-cc-mode aria-pressed="true">color</button>
  <button type="button" class="cc-btn" data-cc-barrel aria-pressed="true">barrel</button>
  <span class="cc-readout" data-cc-pattern aria-live="polite">—</span>
  <button type="button" class="cc-btn" data-cc-restart>restart ↻</button>
</div>

<style>
  .collider-controls {
    position: fixed;
    bottom: calc(var(--space-4) + env(safe-area-inset-bottom, 0px));
    right: var(--space-4);
    z-index: var(--z-dock);
    display: flex;
    align-items: center;
    gap: var(--space-2);
    pointer-events: auto;
  }
  .cc-btn,
  .cc-readout {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-label);
    color: var(--text-secondary);
    background: color-mix(in srgb, var(--surface-raised) 92%, transparent);
    border: var(--hairline) solid var(--border-strong);
    border-radius: var(--radius-pill);
    padding: 7px 13px;
    box-shadow: var(--shadow-dock);
  }
  .cc-btn {
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .cc-btn:hover {
    color: var(--text-primary);
    border-color: var(--accent-line);
  }
  .cc-btn[aria-pressed="true"] {
    color: var(--accent);
    border-color: var(--accent-line);
  }
  .cc-btn:focus-visible {
    outline: none;
    box-shadow: var(--ring);
  }
  /* the readout: a small non-interactive island showing the current topology */
  .cc-readout {
    color: var(--accent);
    min-width: 9.5rem;
    text-align: center;
    white-space: nowrap;
  }
</style>

<script>
  const modeBtn = document.querySelector<HTMLButtonElement>("[data-cc-mode]");
  const restartBtn = document.querySelector<HTMLButtonElement>("[data-cc-restart]");
  const patternEl = document.querySelector<HTMLElement>("[data-cc-pattern]");

  // three modes cycled by the button; colourful is the default (unset → colourful).
  const MODES = ["colourful", "quiet", "muted"] as const;
  type Mode = typeof MODES[number];
  const getMode = (): Mode => {
    try { const v = localStorage.getItem("collider-mode"); return (MODES as readonly string[]).includes(v ?? "") ? (v as Mode) : "colourful"; } catch (e) { return "colourful"; }
  };
  // short button labels: colourful → "color", quiet → "type", muted → "mono".
  const LABEL: Record<Mode, string> = { colourful: "color", quiet: "type", muted: "mono" };
  const apply = (m: Mode) => {
    if (modeBtn) {
      modeBtn.setAttribute("aria-pressed", String(m !== "muted"));   // styled "active" unless monochrome
      modeBtn.setAttribute("aria-label", "collision colouring: " + m);
      modeBtn.textContent = LABEL[m];
    }
    (window as any).colliderSetMode?.(m);
  };
  apply(getMode());
  modeBtn?.addEventListener("click", () => {
    const next = MODES[(MODES.indexOf(getMode()) + 1) % MODES.length];
    try { localStorage.setItem("collider-mode", next); } catch (e) {}
    apply(next);
  });
  // barrel toggle: show/hide the cylindrical detector wireframe (default on)
  const barrelBtn = document.querySelector<HTMLButtonElement>("[data-cc-barrel]");
  const getBarrel = () => { try { const v = localStorage.getItem("collider-barrel"); return v === null ? true : v === "on"; } catch (e) { return true; } };
  const applyBarrel = (on: boolean) => {
    barrelBtn?.setAttribute("aria-pressed", String(on));
    (window as any).colliderSetBarrel?.(on);
  };
  applyBarrel(getBarrel());
  barrelBtn?.addEventListener("click", () => {
    const on = !getBarrel();
    try { localStorage.setItem("collider-barrel", on ? "on" : "off"); } catch (e) {}
    applyBarrel(on);
  });

  restartBtn?.addEventListener("click", () => (window as any).colliderRestart?.());

  // the readout follows the current topology
  if (patternEl) {
    const initial = (window as any).colliderPattern;
    if (initial) patternEl.textContent = initial;
    window.addEventListener("collider:pattern", (e) => {
      patternEl.textContent = (e as CustomEvent).detail;
    });
  }
</script>
